{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "startCommand": "pnpm --filter @imbobi/api start",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 3
  },
  "plugins": [
    {
      "source": "https://github.com/railwayapp-templates/postgres"
    },
    {
      "source": "https://github.com/railwayapp-templates/redis"
    }
  ]
}
