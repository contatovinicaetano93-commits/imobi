{
  "name": "@imbobi/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "cd ../.. && pnpm --filter @imbobi/schemas build && cd services/api && prisma generate --schema prisma/schema.prisma && nest build",
    "dev": "nest start --watch",
    "start": "prisma migrate deploy --schema prisma/schema.prisma && node dist/main.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "bash test-e2e.sh",
    "test:e2e:watch": "bash test-e2e.sh --watch",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "seed": "ts-node --project tsconfig.json src/seeds/seed.ts",
    "seed:prod": "node -r ts-node/register -r tsconfig-paths/register src/seeds/seed.ts",
    "seed:dev": "ts-node --project tsconfig.json src/seeds/dev-seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@fastify/multipart": "^10.0.0",
    "@imbobi/core": "workspace:*",
    "@imbobi/schemas": "workspace:*",
    "@keyv/redis": "^5.1.6",
    "@nestjs/bull": "^10.0.0",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-fastify": "^10.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.0.0",
    "@sentry/node": "^10.55.0",
    "@sentry/tracing": "^7.120.4",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.10.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.0",
    "exifr": "^7.1.3",
    "firebase-admin": "^13.10.0",
    "keyv": "^5.6.0",
    "nodemailer": "^8.0.9",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^5.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "sharp": "^0.35.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/testing": "^10.4.22",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "class-validator": "^0.14.0",
    "dotenv": "^17.4.2",
    "fastify": "^4.29.1",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.5.0"
  }
}
