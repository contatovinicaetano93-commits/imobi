{
  "name": "@imbobi/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "node --watch dist/services/api/src/main.js",
    "start": "node dist/services/api/src/main.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "jest --config jest.e2e.config.js --runInBand",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-secrets-manager": "^3.1058.0",
    "@aws-sdk/client-ses": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@imbobi/schemas": "workspace:*",
    "@nestjs/bull": "^11.0.0",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/platform-fastify": "^10.0.0",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.0.0",
    "@sentry/nestjs": "^10.55.0",
    "@sentry/profiling-node": "^10.55.0",
    "@sentry/tracing": "^7.120.4",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.10.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "exifr": "^7.1.3",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.2.0",
    "nodemailer": "^8.0.9",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "sharp": "^0.33.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@fastify/static": "^6.12.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "module-alias": "^2.3.4",
    "prisma": "^5.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.5.0"
  }
}
