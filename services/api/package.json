{
  "name": "@imbobi/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/services/api/src/main.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "seed": "ts-node --project tsconfig.json src/seeds/seed.ts",
    "seed:prod": "node -r ts-node/register -r tsconfig-paths/register src/seeds/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@imbobi/schemas": "workspace:*",
    "@nestjs/bull": "^10.0.0",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-fastify": "^10.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.0.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.10.0",
    "cache-manager": "^7.2.8",
    "exifr": "^7.1.3",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.2.0",
    "nodemailer": "^8.0.9",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "sharp": "^0.33.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "prisma": "^5.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.5.0"
  }
}
