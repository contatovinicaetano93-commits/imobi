generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TipoUsuario {
  TOMADOR
  GESTOR_OBRA
  ADMIN
  PARCEIRO
}

enum KycStatus {
  PENDENTE
  EM_ANALISE
  APROVADO
  REJEITADO
}

enum StatusCredito {
  ANALISE
  APROVADO
  ATIVO
  QUITADO
  INADIMPLENTE
  CANCELADO
}

enum TipoObra {
  RESIDENCIAL
  COMERCIAL
  MISTO
}

enum StatusObra {
  PLANEJAMENTO
  EM_ANDAMENTO
  PAUSADA
  CONCLUIDA
  CANCELADA
}

enum StatusEtapa {
  PENDENTE
  EM_PROGRESSO
  AGUARDANDO_VISTORIA
  APROVADA
  REJEITADA
}

enum StatusLiberacao {
  PENDENTE
  PROCESSANDO
  CONCLUIDA
  FALHA
}

// ─────────────────────────────────────────────
// USUARIO
// ─────────────────────────────────────────────

model Usuario {
  id          String     @id @default(uuid())
  nome        String     @db.VarChar(120)
  cpf         String     @unique @db.VarChar(11)
  email       String     @unique @db.VarChar(255)
  telefone    String     @db.VarChar(11)
  senhaHash   String
  tipo        TipoUsuario @default(TOMADOR)
  kycStatus   KycStatus   @default(PENDENTE)
  ativo       Boolean     @default(true)
  criadoEm   DateTime    @default(now())
  atualizadoEm DateTime  @updatedAt

  creditos    Credito[]
  obras       Obra[]
  evidencias  EvidenciaEtapa[]
  sessoes     SessaoToken[]
  scoreHistorico ScoreHistorico[]

  @@index([email])
  @@index([cpf])
  @@map("usuarios")
}

// ─────────────────────────────────────────────
// SESSÃO / AUTH
// ─────────────────────────────────────────────

model SessaoToken {
  id          String   @id @default(uuid())
  usuarioId   String
  refreshToken String  @unique
  expiresAt   DateTime
  revogado    Boolean  @default(false)
  criadoEm   DateTime @default(now())

  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("sessao_tokens")
}

// ─────────────────────────────────────────────
// CRÉDITO
// ─────────────────────────────────────────────

model Credito {
  id                  String        @id @default(uuid())
  usuarioId           String
  valorAprovado       Decimal       @db.Decimal(12, 2)
  valorLiberado       Decimal       @default(0) @db.Decimal(12, 2)
  taxaMensal          Decimal       @db.Decimal(6, 4)
  prazoMeses          Int
  status              StatusCredito @default(ANALISE)
  finalidade          String?       @db.VarChar(500)
  rendaDeclarada      Decimal?      @db.Decimal(12, 2)
  dataAprovacao       DateTime?
  dataVencimento      DateTime?
  criadoEm           DateTime      @default(now())
  atualizadoEm       DateTime      @updatedAt

  usuario             Usuario       @relation(fields: [usuarioId], references: [id])
  obras               Obra[]
  liberacoes          LiberacaoParcela[]

  @@index([usuarioId])
  @@index([status])
  @@map("creditos")
}

// ─────────────────────────────────────────────
// OBRA
// ─────────────────────────────────────────────

model Obra {
  id                      String     @id @default(uuid())
  usuarioId               String
  creditoId               String?
  nome                    String     @db.VarChar(120)
  // Endereço como JSON estruturado
  enderecoJson            Json
  // Coordenadas — armazenadas como floats (PostGIS geometry gerada via raw SQL na migration)
  geoLatitude             Decimal    @db.Decimal(10, 8)
  geoLongitude            Decimal    @db.Decimal(11, 8)
  raioValidacaoMetros     Int        @default(80)
  areaM2                  Decimal    @db.Decimal(8, 2)
  tipoObra                TipoObra   @default(RESIDENCIAL)
  status                  StatusObra @default(PLANEJAMENTO)
  dataInicio              DateTime?
  dataConclusaoPrevista   DateTime?
  dataConclusaoReal       DateTime?
  criadoEm               DateTime   @default(now())
  atualizadoEm           DateTime   @updatedAt

  usuario                 Usuario    @relation(fields: [usuarioId], references: [id])
  credito                 Credito?   @relation(fields: [creditoId], references: [id])
  etapas                  EtapaObra[]

  @@index([usuarioId])
  @@index([status])
  @@map("obras")
}

// ─────────────────────────────────────────────
// ETAPA DA OBRA
// ─────────────────────────────────────────────

model EtapaObra {
  id                    String      @id @default(uuid())
  obraId                String
  nome                  String      @db.VarChar(100)
  descricao             String?     @db.VarChar(1000)
  ordem                 Int
  percentualObra        Decimal     @db.Decimal(5, 2)
  valorLiberacao        Decimal     @default(0) @db.Decimal(12, 2)
  status                StatusEtapa @default(PENDENTE)
  dataInicio            DateTime?
  dataConclusaoPrevista DateTime?
  dataConclusaoReal     DateTime?
  criadoEm             DateTime    @default(now())
  atualizadoEm         DateTime    @updatedAt

  obra                  Obra        @relation(fields: [obraId], references: [id], onDelete: Cascade)
  evidencias            EvidenciaEtapa[]
  liberacoes            LiberacaoParcela[]

  @@unique([obraId, ordem])
  @@index([obraId])
  @@map("etapas_obra")
}

// ─────────────────────────────────────────────
// EVIDÊNCIA (foto geovalidada)
// ─────────────────────────────────────────────

model EvidenciaEtapa {
  id               String   @id @default(uuid())
  etapaId          String
  usuarioId        String
  fotoUrl          String   @db.VarChar(2048)
  fotoKey          String   @db.VarChar(512) // chave S3
  latCaptura       Decimal  @db.Decimal(10, 8)
  lngCaptura       Decimal  @db.Decimal(11, 8)
  accuracyMetros   Decimal  @db.Decimal(6, 2)
  distanciaObra    Decimal? @db.Decimal(8, 2) // preenchido pelo servidor
  exifTimestamp    DateTime?
  validada         Boolean  @default(false)
  observacao       String?  @db.VarChar(1000)
  rejeitadaMotivo  String?  @db.VarChar(500)
  criadoEm        DateTime @default(now())

  etapa            EtapaObra @relation(fields: [etapaId], references: [id], onDelete: Cascade)
  usuario          Usuario   @relation(fields: [usuarioId], references: [id])

  @@index([etapaId])
  @@index([usuarioId])
  @@index([validada])
  @@map("evidencias_etapa")
}

// ─────────────────────────────────────────────
// LIBERAÇÃO DE PARCELA
// ─────────────────────────────────────────────

model LiberacaoParcela {
  id               String          @id @default(uuid())
  creditoId        String
  etapaId          String
  valor            Decimal         @db.Decimal(12, 2)
  status           StatusLiberacao @default(PENDENTE)
  observacaoGestor String?         @db.VarChar(1000)
  processadoEm    DateTime?
  criadoEm        DateTime        @default(now())

  credito          Credito   @relation(fields: [creditoId], references: [id])
  etapa            EtapaObra @relation(fields: [etapaId], references: [id])

  @@index([creditoId])
  @@index([etapaId])
  @@index([status])
  @@map("liberacoes_parcela")
}

// ─────────────────────────────────────────────
// SCORE DE CONSTRUTIBILIDADE
// ─────────────────────────────────────────────

model ScoreHistorico {
  id           String   @id @default(uuid())
  usuarioId    String
  score        Int      // 0–1000
  motivo       String?  @db.VarChar(500)
  criadoEm    DateTime @default(now())

  usuario      Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@map("score_historico")
}
