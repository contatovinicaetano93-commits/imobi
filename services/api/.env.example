# PostgreSQL + PostGIS Configuration
DATABASE_URL="postgresql://imbobi:senha@localhost:5432/imbobi_dev"

# Redis Cache Configuration
REDIS_URL="redis://localhost:6379"

# JWT Configuration (MUST be >64 chars of random data for production)
# Generate with: openssl rand -base64 64
JWT_SECRET="your-secret-key-change-this-in-production-must-be-at-least-64-chars-1234567890abcdefghijklmnop"
JWT_EXPIRE_IN="24h"

# CORS Configuration (comma-separated origins)
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Encryption Key for sensitive fields (CPF, CNPJ, etc)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="base64-encoded-32-random-bytes-change-in-production"

# SendGrid Email Configuration
SENDGRID_API_KEY="SG.your_sendgrid_api_key_here"

# AWS S3 Configuration (for work photos)
AWS_ACCESS_KEY_ID="your_aws_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret"
AWS_S3_BUCKET="imbobi-obras-dev"
AWS_REGION="us-east-1"

# Firebase Cloud Messaging Configuration (for push notifications)
FIREBASE_PROJECT_ID="your_firebase_project"
FIREBASE_PRIVATE_KEY="your_firebase_key"
FIREBASE_CLIENT_EMAIL="your_firebase_email"

# Environment
NODE_ENV="development"
