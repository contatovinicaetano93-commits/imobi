# imobi API — Environment Template
# Copy to .env and fill values

NODE_ENV=development
API_PORT=4000
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Database (PostGIS required)
DATABASE_URL=postgresql://user:pass@localhost:5432/imobi?schema=public

# Redis
REDIS_URL=redis://localhost:6379
# Or: REDIS_HOST, REDIS_PORT, REDIS_PASSWORD

# Auth
JWT_SECRET=change-me-use-openssl-rand-base64-48-in-production

# Workers — set DISABLE_IN_PROCESS_WORKERS=true on API in production; run main.worker.js separately
DISABLE_IN_PROCESS_WORKERS=false
WORKER_MODE=

# Payments: console | pix | stripe
PAYMENT_PROVIDER=console
PIX_API_URL=
PIX_API_KEY=
STRIPE_SECRET_KEY=

# AWS S3
AWS_S3_BUCKET=imbobi-evidencias
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ENABLE_S3_STORAGE=true

# Email: sendgrid | ses | smtp | console
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=

# Push
ENABLE_PUSH_NOTIFICATIONS=false
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Monitoring
SENTRY_DSN=
SENTRY_RELEASE=
