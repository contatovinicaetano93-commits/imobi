# ══════════════════════════════════════════════════════════════════════
# IMOBI API — variáveis de ambiente
# Copie para .env (dev) ou configure no painel do Render (produção)
# NUNCA commite .env ou .env.production
# ══════════════════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# URL pública da API (usada em links de email, CORS, etc.)
# Produção: https://imobi-api-efgg.onrender.com
APP_URL=http://localhost:4000

# Origens permitidas pelo CORS (vírgula para múltiplas)
# Produção: https://imobi.com.br,https://www.imobi.com.br
CORS_ORIGIN=http://localhost:3000

# ── Banco de dados ────────────────────────────────────────────────────
# Produção: postgresql://user:pass@host:5432/imobi?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/imobi

# ── Redis (BullMQ + Cache) ────────────────────────────────────────────
# Modo 1: URL completa (Upstash / Render Redis)
REDIS_URL=redis://localhost:6379
# Modo 2: host + porta separados (alternativo ao REDIS_URL)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────
# Gere em produção: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Email ─────────────────────────────────────────────────────────────
# Opções: sendgrid | ses | smtp
EMAIL_PROVIDER=smtp
SMTP_FROM=noreply@imobi.com.br

# SendGrid (quando EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# SMTP genérico (quando EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SES (quando EMAIL_PROVIDER=ses)
# AWS_REGION e credenciais abaixo também servem

# ── AWS S3 (fotos de obra e documentos) ──────────────────────────────
# Ative o modo S3: ENABLE_S3_STORAGE=true
ENABLE_S3_STORAGE=false
AWS_S3_BUCKET=imobi-evidencias
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Firebase FCM (push notifications) ────────────────────────────────
# Ative push: ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=false
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Chave privada do service account (com \n literais)
FIREBASE_PRIVATE_KEY=

# ── Monitoramento ─────────────────────────────────────────────────────
# Sentry (opcional — desativado se vazio)
SENTRY_DSN=

# Slack webhook para alertas de worker (opcional)
SLACK_WEBHOOK_URL=

# ── Setup / bootstrap ─────────────────────────────────────────────────
# Usado pelo endpoint POST /api/v1/setup/init (cria o primeiro ADMIN)
# Remova após criar o admin em produção!
# Gere: openssl rand -hex 24
SETUP_SECRET=
