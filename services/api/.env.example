# Environment Configuration
NODE_ENV=development

# Server
PORT=4000

# Database (PostgreSQL)
# For local: postgresql://imbobi:imbobi123@localhost:5432/imbobi_dev?schema=public
# For AWS RDS: postgresql://imbobi:password@your-instance.rds.amazonaws.com:5432/imbobi_dev?schema=public
DATABASE_URL="postgresql://imbobi:imbobi123@localhost:5432/imbobi_dev?schema=public"

# JWT Secret (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
# Must be at least 64 characters for production
JWT_SECRET="your-super-secret-jwt-key-minimum-64-characters-must-be-generated-securely"

# Encryption Key (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
# Used for sensitive data encryption (AES-256-GCM)
ENCRYPTION_KEY="base64-encoded-32-byte-key-for-aes-256-encryption"

# Redis (optional, for caching and job queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3000,http://localhost:8081,http://localhost:19000"

# Email Service (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@imbobi.com

# AWS S3 (for photo storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=imbobi-assets

# Firebase (optional, for push notifications)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase@your-project.iam.gserviceaccount.com

# Expo Public API URL (for mobile)
EXPO_PUBLIC_API_URL="http://localhost:4000/api/v1"

# EAS Project ID (for mobile builds)
EAS_PROJECT_ID="your-eas-project-id"
