# PostgreSQL + PostGIS Configuration
DATABASE_URL="postgresql://imbobi:senha@localhost:5432/imbobi_dev"

# Redis Cache Configuration
REDIS_URL="redis://localhost:6379"

# JWT Configuration (minimum 64 characters for production)
JWT_SECRET="your-secret-key-change-this-in-production-must-be-at-least-64-chars-1234567890"
JWT_EXPIRE_IN="24h"

# SendGrid Email Configuration
SENDGRID_API_KEY="SG.your_sendgrid_api_key_here"

# AWS S3 Configuration (for work photos)
AWS_ACCESS_KEY_ID="your_aws_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret"
AWS_S3_BUCKET="imbobi-obras-dev"
AWS_REGION="us-east-1"

# Firebase Cloud Messaging Configuration (for push notifications)
FIREBASE_PROJECT_ID="your_firebase_project"
FIREBASE_PRIVATE_KEY="your_firebase_key"
FIREBASE_CLIENT_EMAIL="your_firebase_email"

# Environment
NODE_ENV="development"
