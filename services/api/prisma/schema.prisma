// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Usuários ──────────────────────────────────────────────────────────

model Usuario {
  usuarioId     String   @id @default(uuid())
  nome          String
  cpf           String   @unique
  email         String   @unique
  telefone      String
  passwordHash  String
  tipo          UsuarioTipo @default(TOMADOR)
  comercialRole ComercialRole?
  kycStatus           KycStatus @default(PENDENTE)
  consentidoTermos    Boolean   @default(false)
  consentidoPrivacy   Boolean   @default(false)
  consentidoKyc       Boolean   @default(false)
  consentidoMarketing Boolean   @default(false)
  consentidoEm        DateTime?
  passwordResetToken    String?
  passwordResetExpires  DateTime?
  deletadoEm          DateTime?
  criadoEm            DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  sessoes       SessaoToken[]
  creditos      Credito[]
  obras         Obra[]
  scoreHistorico ScoreHistorico[]
  kycDocumentos KycDocumento[] @relation("KycDocumentos")
  notificacoes  Notificacao[]
  fcmTokens     UsuarioFcmToken[]
  etapaAuditLogs EtapaAuditLog[] @relation("EtapaAuditLogs")
  kycAuditLogs  KycAuditLog[] @relation("KycAuditLogs")
  leadsGerenciados Lead[] @relation("LeadUsuarios")
  dossies       DossieCredito[]
  dossieAuditLogs DossieAuditLog[] @relation("DossieAuditLogs")

  @@index([email])
  @@index([cpf])
  @@index([deletadoEm])
}

enum UsuarioTipo {
  TOMADOR
  GESTOR_OBRA
  ADMIN
  PARCEIRO
}

enum KycStatus {
  PENDENTE
  EM_VERIFICACAO
  APROVADO
  REJEITADO
}

// ── Sessões ───────────────────────────────────────────────────────────

model SessaoToken {
  sessionId     String    @id @default(uuid())
  usuarioId     String
  usuario       Usuario   @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  refreshToken  String    @unique
  expiresAt     DateTime
  revogadoEm    DateTime?
  criadoEm      DateTime  @default(now())

  @@index([usuarioId])
}

model UsuarioFcmToken {
  usuarioId   String
  token       String
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuario     Usuario  @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)

  @@id([usuarioId, token])
  @@index([ativo])
  @@map("usuario_fcm_tokens")
}

// ── Créditos ──────────────────────────────────────────────────────────

model Credito {
  creditoId       String    @id @default(uuid())
  usuarioId       String
  usuario         Usuario   @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  valorAprovado   Float
  valorLiberado   Float
  taxaMensal      Float     @default(0.0099)
  prazoMeses      Int
  status          CreditoStatus @default(ATIVO)
  dataAprovacao   DateTime  @default(now())
  dataVencimento  DateTime?
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt

  obras           Obra[]
  liberacoes      LiberacaoParcela[]
  dossies         DossieCredito[]

  @@index([usuarioId])
  @@index([status])
}

enum CreditoStatus {
  ATIVO
  SUSPENSO
  VENCIDO
  QUITADO
}

// ── Obras ─────────────────────────────────────────────────────────────

model Obra {
  obraId              String   @id @default(uuid())
  creditoId           String?
  credito             Credito? @relation(fields: [creditoId], references: [creditoId], onDelete: SetNull)
  usuarioId           String
  usuario             Usuario  @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  nome                String
  endereco            String
  geoLatitude         Float
  geoLongitude        Float
  raioValidacaoMetros Int      @default(50)
  areaM2              Float?
  tipo                String?
  status              ObraStatus @default(PLANEJAMENTO)
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  etapas              EtapaObra[]
  evidencias          EvidenciaEtapa[]
  leads               Lead[]

  @@index([usuarioId])
  @@index([creditoId])
  @@index([status])
}

enum ObraStatus {
  PLANEJAMENTO
  EM_EXECUCAO
  PAUSADA
  CONCLUIDA
  CANCELADA
}

// ── Etapas de Obra ────────────────────────────────────────────────────

model EtapaObra {
  etapaId             String   @id @default(uuid())
  obraId              String
  obra                Obra     @relation(fields: [obraId], references: [obraId], onDelete: Cascade)
  nome                String
  ordem               Int
  percentualObra      Float
  valorLiberacao      Float
  status              EtapaStatus @default(PLANEJADA)
  dataConclusaoPrevista DateTime?
  dataConclusaoReal   DateTime?
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  evidencias          EvidenciaEtapa[]
  auditLogs           EtapaAuditLog[]

  @@unique([obraId, ordem])
  @@index([obraId])
  @@index([status])
}

enum EtapaStatus {
  PLANEJADA
  EM_EXECUCAO
  AGUARDANDO_VISTORIA
  REPROVADA
  CONCLUIDA
}

// ── Evidências de Etapa ───────────────────────────────────────────────

model EvidenciaEtapa {
  evidenciaId       String   @id @default(uuid())
  etapaId           String
  etapa             EtapaObra @relation(fields: [etapaId], references: [etapaId], onDelete: Cascade)
  obraId            String
  obra              Obra     @relation(fields: [obraId], references: [obraId], onDelete: Cascade)
  fotoUrl           String
  latCaptura        Float
  lngCaptura        Float
  accuracyMetros    Float?
  distanciaObra     Float?
  validada          Boolean  @default(false)
  observacao        String?
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  @@index([etapaId])
  @@index([obraId])
  @@index([validada])
}

// ── Liberações de Parcelas ────────────────────────────────────────────

model LiberacaoParcela {
  liberacaoId     String   @id @default(uuid())
  creditoId       String
  credito         Credito  @relation(fields: [creditoId], references: [creditoId], onDelete: Cascade)
  valor           Float
  status          LiberacaoStatus @default(PENDENTE)
  motivo          String?
  processadoEm    DateTime?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@index([creditoId])
  @@index([status])
}

enum LiberacaoStatus {
  PENDENTE
  PROCESSANDO
  CONCLUIDA
  FALHA
}

// ── Score de Construtibilidade ────────────────────────────────────────

model ScoreHistorico {
  scoreId     String   @id @default(uuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  score       Int
  motivo      String?
  criadoEm    DateTime @default(now())

  @@index([usuarioId])
  @@index([criadoEm])
}

// ── KYC Documents ──────────────────────────────────────────────────────

model KycDocumento {
  kycDocumentoId String   @id @default(uuid())
  usuarioId      String
  usuario        Usuario  @relation("KycDocumentos", fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  tipo           String   // RG, CNH, Selfie, Comprovante de Residência, etc.
  url            String   // S3 URL
  status         KycDocumentoStatus @default(PENDENTE)
  motivo_rejeicao String?
  analisadoPor   String?  // usuarioId of reviewer
  analisadoEm    DateTime?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
  auditLogs      KycAuditLog[]

  @@index([usuarioId])
  @@index([status])
  @@index([criadoEm])
}

enum KycDocumentoStatus {
  PENDENTE
  APROVADO
  REJEITADO
}

// ── Notificações ───────────────────────────────────────────────────

model Notificacao {
  notificacaoId String   @id @default(uuid())
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  tipo          TipoNotificacao
  titulo        String
  mensagem      String
  link          String?
  lida          Boolean  @default(false)
  lidoEm        DateTime?
  criadoEm      DateTime @default(now())

  @@index([usuarioId])
  @@index([lida])
  @@index([criadoEm])
}

enum TipoNotificacao {
  ETAPA_APROVADA
  ETAPA_REPROVADA
  PARCELA_LIBERADA
  PARCELA_FALHA
  CREDITO_APROVADO
  KYC_APROVADO
  KYC_REJEITADO
  OBRA_CRIADA
  SCORE_ATUALIZADO
  VISTORIA_PENDENTE
}

// ── Auditoria de Etapas ─────────────────────────────────────────────

model EtapaAuditLog {
  auditId         String   @id @default(uuid())
  etapaId         String
  etapa           EtapaObra @relation(fields: [etapaId], references: [etapaId], onDelete: Cascade)
  acaoTipo        String   // APROVADA, REJEITADA, EDITADA
  usuarioId       String
  usuario         Usuario  @relation("EtapaAuditLogs", fields: [usuarioId], references: [usuarioId], onDelete: Restrict)
  observacoes     String?
  criadoEm        DateTime @default(now())

  @@index([etapaId])
  @@index([usuarioId])
  @@index([criadoEm])
}

// ── Auditoria de KYC ────────────────────────────────────────────────

model KycAuditLog {
  auditId         String      @id @default(uuid())
  kycDocumentoId  String
  kyc             KycDocumento @relation(fields: [kycDocumentoId], references: [kycDocumentoId], onDelete: Cascade)
  acaoTipo        String      // APROVADO, REJEITADO
  usuarioId       String
  usuario         Usuario     @relation("KycAuditLogs", fields: [usuarioId], references: [usuarioId], onDelete: Restrict)
  motivo          String?
  criadoEm        DateTime @default(now())

  @@index([kycDocumentoId])
  @@index([usuarioId])
  @@index([criadoEm])
}

// ── Comercial: Leads & Pipeline (Phase 11) ──────────────────────────

enum LeadFonte {
  WEBSITE
  INDICACAO
  MARKETPLACE
  CAMPANHA_DIGITAL
  OFFLINE
  PARCEIRO
}

enum LeadSegmento {
  NOVO
  RETORNO
  CONCORRENTE
}

enum LeadActivityTipo {
  CALL_OUTBOUND
  CALL_INBOUND
  EMAIL_SENT
  EMAIL_RECEIVED
  MEETING_SCHEDULED
  MEETING_COMPLETED
  PROPOSAL_SENT
  DOCUMENT_REQUESTED
  PAYMENT_RECEIVED
  STAGE_CHANGED
  NOTE_ADDED
  FOLLOW_UP_SET
}

enum ComercialRole {
  GERENTE_VENDAS
  REPRESENTANTE
}

model PipelineStage {
  stageId         String   @id @default(uuid())
  nome            String   @unique
  ordem           Int      @unique
  descricao       String?
  corHex          String   @default("#999999")
  taxaConversao   Float    @default(0.0)
  diasMedioStage  Int      @default(7)

  leads           Lead[]

  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@index([ordem])
}

model Lead {
  leadId              String   @id @default(uuid())
  obraId              String?
  obra                Obra?    @relation(fields: [obraId], references: [obraId], onDelete: SetNull)
  usuarioId           String?
  usuario             Usuario? @relation("LeadUsuarios", fields: [usuarioId], references: [usuarioId], onDelete: SetNull)
  atribuidoEm         DateTime?

  clienteNome         String
  clienteEmail        String
  clienteTelefone     String
  clienteCpf          String?

  stageId             String
  stage               PipelineStage @relation(fields: [stageId], references: [stageId], onDelete: Restrict)

  fonte               LeadFonte     @default(WEBSITE)
  tipoObra            String?
  segmentoCliente     LeadSegmento  @default(NOVO)

  condicoes           String?
  proximoAcompanhamento DateTime?
  statusUltimo        String?

  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt
  convertidoEm        DateTime?

  scoreHistorico      ConversionScore[]
  atividades          LeadActivity[]

  @@index([obraId])
  @@index([usuarioId])
  @@index([stageId])
  @@index([fonte])
  @@index([segmentoCliente])
  @@index([criadoEm])
  @@index([convertidoEm])
}

model ConversionScore {
  scoreId             String   @id @default(uuid())
  leadId              String
  lead                Lead     @relation(fields: [leadId], references: [leadId], onDelete: Cascade)

  scoreFinal          Float
  probabilidadeClosing Float
  dataEstimadaClosing DateTime?

  fonteScore          Float    @default(0.0)
  tipoObraScore       Float    @default(0.0)
  segmentoScore       Float    @default(0.0)
  engajamentoScore    Float    @default(0.0)
  historicoScore      Float    @default(0.0)

  versaoAlgoritmo     String   @default("v1")

  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@index([leadId])
  @@index([scoreFinal])
  @@index([atualizadoEm])
}

model LeadActivity {
  atividadeId     String   @id @default(uuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [leadId], onDelete: Cascade)

  tipo            LeadActivityTipo
  descricao       String
  usuarioId       String

  criadoEm        DateTime @default(now())

  @@index([leadId])
  @@index([tipo])
  @@index([criadoEm])
}

// ── Dossiê de Crédito (Phase 12) ────────────────────────────────────

enum DossieStatus {
  RASCUNHO
  EM_ANALISE
  PENDENCIA
  APROVADO
  REPROVADO
}

enum DossieUnidadeStatus {
  VENDIDA
  PERMUTA
  ESTOQUE
  QUITADA
}

enum SistemaAmortizacao {
  PRICE
  SAC
  SACOC
}

enum DossieDocumentoTipo {
  DEMONSTRACAO_FINANCEIRA
  APRESENTACAO_PROJETO
  APRESENTACAO_EMPRESA
  ORGANOGRAMA_SOCIETARIO
  ACORDO_PERMUTA
  CRONOGRAMA_FISICO_FINANCEIRO
  OUTRO
}

model DossieCredito {
  dossieId         String   @id @default(uuid())
  creditoId        String?
  credito          Credito? @relation(fields: [creditoId], references: [creditoId], onDelete: SetNull)
  usuarioId        String
  usuario          Usuario  @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  status           DossieStatus @default(RASCUNHO)
  etapasConcluidas Int[]    @default([]) // etapas do wizard web (1..7) já concluídas

  // Ficha do Empreendimento
  nomeEmpreendimento   String
  speRazaoSocial       String?
  speCnpj              String?
  endereco             String?
  cidade               String?
  uf                   String?
  tipoEmpreendimento   String?  // RESIDENCIAL, COMERCIAL, MISTO
  patrimonioAfetacao   Boolean  @default(false)
  areaTerrenoM2        Float?
  areaConstruidaM2     Float?
  areaPrivativaTotalM2 Float?
  valorTerreno         Float?
  dataLancamento       DateTime?
  dataInicioObras      DateTime?
  dataPrevisaoTermino  DateTime?
  dataHabiteSe         DateTime?
  alienacaoFiduciariaTerreno  Boolean @default(false)
  alienacaoFiduciariaUnidades Boolean @default(false)
  seguroObra           Boolean  @default(false)
  percentualEntrada    Float?
  percentualObras      Float?
  percentualChaves     Float?
  orcamentoOriginal    Float?
  orcamentoAtual       Float?
  custoIncorrido       Float?
  custoAIncorrer       Float?
  percentualCronogramaFisico     Float?
  percentualCronogramaFinanceiro Float?

  // Permutas (relevante apenas quando há unidades PERMUTA)
  possuiAcordoNaoConcorrenciaPermuta Boolean?

  // Empresa desenvolvedora/controladora
  empresaNome        String?
  empresaCnpj        String?
  empresaWebsite     String?
  empresaAnoFundacao Int?

  submetidoEm  DateTime?
  analisadoPor String?  // usuarioId of reviewer
  analisadoEm  DateTime?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  unidades   DossieUnidade[]
  recebiveis DossieRecebivel[]
  distratos  DossieDistrato[]
  documentos DossieDocumento[]
  auditLogs  DossieAuditLog[]

  @@index([usuarioId])
  @@index([creditoId])
  @@index([status])
  @@index([criadoEm])
}

// ── Tabela de Unidades do Dossiê ────────────────────────────────────

model DossieUnidade {
  unidadeId          String   @id @default(uuid())
  dossieId           String
  dossie             DossieCredito @relation(fields: [dossieId], references: [dossieId], onDelete: Cascade)
  numeroContrato     String?
  numeroUnidade      String
  areaPrivativaM2    Float
  clienteNome        String?
  clienteCpfCnpj     String?
  dataVenda          DateTime?
  valorVenda         Float?
  valorTabela        Float?
  status             DossieUnidadeStatus @default(ESTOQUE)
  indexador          String?  // INCC, IGP-M, IPCA, etc.
  taxaJurosMensal    Float?   // % a.m.
  sistemaAmortizacao SistemaAmortizacao?
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  recebiveis DossieRecebivel[]
  distratos  DossieDistrato[]

  @@unique([dossieId, numeroUnidade])
  @@index([dossieId])
  @@index([status])
}

// ── Carteira de Recebíveis do Dossiê ────────────────────────────────

model DossieRecebivel {
  recebivelId    String   @id @default(uuid())
  dossieId       String
  dossie         DossieCredito @relation(fields: [dossieId], references: [dossieId], onDelete: Cascade)
  unidadeId      String?
  unidade        DossieUnidade? @relation(fields: [unidadeId], references: [unidadeId], onDelete: SetNull)
  numeroContrato String?
  numeroUnidade  String
  clienteNome    String?
  parcelaAtual   Int
  totalParcelas  Int
  dataVencimento DateTime
  dataPagamento  DateTime?
  valorParcela   Float
  valorRecebido  Float?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  @@index([dossieId])
  @@index([unidadeId])
  @@index([dataVencimento])
  @@index([dataPagamento])
}

// ── Distratos do Dossiê ─────────────────────────────────────────────

model DossieDistrato {
  distratoId      String   @id @default(uuid())
  dossieId        String
  dossie          DossieCredito @relation(fields: [dossieId], references: [dossieId], onDelete: Cascade)
  unidadeId       String?
  unidade         DossieUnidade? @relation(fields: [unidadeId], references: [unidadeId], onDelete: SetNull)
  numeroContrato  String?
  numeroUnidade   String
  clienteNome     String?
  dataVenda       DateTime?
  dataDistrato    DateTime
  valorRecebido   Float?
  valorRestituido Float?
  motivo          String?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@index([dossieId])
  @@index([unidadeId])
  @@index([dataDistrato])
}

// ── Documentos do Dossiê (S3) ───────────────────────────────────────

model DossieDocumento {
  dossieDocumentoId String   @id @default(uuid())
  dossieId          String
  dossie            DossieCredito @relation(fields: [dossieId], references: [dossieId], onDelete: Cascade)
  tipo              DossieDocumentoTipo
  url               String   // S3 URL
  nomeArquivo       String?
  anoExercicio      Int?     // obrigatório quando tipo = DEMONSTRACAO_FINANCEIRA
  descricao         String?  // obrigatório quando tipo = OUTRO
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  @@index([dossieId])
  @@index([tipo])
}

// ── Auditoria do Dossiê ─────────────────────────────────────────────

model DossieAuditLog {
  auditId        String   @id @default(uuid())
  dossieId       String
  dossie         DossieCredito @relation(fields: [dossieId], references: [dossieId], onDelete: Cascade)
  acaoTipo       String   // SUBMETIDO, STATUS_ALTERADO, ETAPA_CONCLUIDA, etc.
  statusAnterior DossieStatus?
  statusNovo     DossieStatus?
  usuarioId      String
  usuario        Usuario  @relation("DossieAuditLogs", fields: [usuarioId], references: [usuarioId], onDelete: Restrict)
  observacoes    String?
  criadoEm       DateTime @default(now())

  @@index([dossieId])
  @@index([usuarioId])
  @@index([criadoEm])
}
