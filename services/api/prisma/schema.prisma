// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Usuários ──────────────────────────────────────────────────────────

model Usuario {
  usuarioId     String   @id @default(uuid())
  nome          String
  cpf           String   @unique
  email         String   @unique
  telefone      String
  passwordHash  String
  tipo          UsuarioTipo @default(TOMADOR)
  kycStatus     KycStatus @default(PENDENTE)
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt
  deletadoEm    DateTime?

  sessoes       SessaoToken[]
  creditos      Credito[]
  obras         Obra[]
  scoreHistorico ScoreHistorico[]
  kycDocumentos KycDocumento[] @relation("KycDocumentos")
  notificacoes  Notificacao[]
  fcmTokens     UsuarioFcmToken[]
  leadsCreated  Lead[] @relation("LeadsCreatedBy")
  leadActivities LeadActivity[] @relation("LeadActivities")

  @@index([email])
  @@index([cpf])
}

enum UsuarioTipo {
  TOMADOR
  GESTOR_OBRA
  ADMIN
  PARCEIRO
}

enum KycStatus {
  PENDENTE
  EM_VERIFICACAO
  APROVADO
  REJEITADO
}

// ── Sessões ───────────────────────────────────────────────────────────

model SessaoToken {
  sessionId     String    @id @default(uuid())
  usuarioId     String
  usuario       Usuario   @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  refreshToken  String    @unique
  expiresAt     DateTime
  revogadoEm    DateTime?
  criadoEm      DateTime  @default(now())

  @@index([usuarioId])
}

model UsuarioFcmToken {
  usuarioId   String
  token       String
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuario     Usuario  @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)

  @@id([usuarioId, token])
  @@index([ativo])
  @@map("usuario_fcm_tokens")
}

// ── Créditos ──────────────────────────────────────────────────────────

model Credito {
  creditoId       String    @id @default(uuid())
  usuarioId       String
  usuario         Usuario   @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  valorAprovado   Float
  valorLiberado   Float
  taxaMensal      Float     @default(0.0099)
  prazoMeses      Int
  status          CreditoStatus @default(ATIVO)
  dataAprovacao   DateTime  @default(now())
  dataVencimento  DateTime?
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt

  obras           Obra[]
  liberacoes      LiberacaoParcela[]

  @@index([usuarioId])
  @@index([status])
}

enum CreditoStatus {
  ATIVO
  SUSPENSO
  VENCIDO
  QUITADO
}

// ── Obras ─────────────────────────────────────────────────────────────

model Obra {
  obraId              String   @id @default(uuid())
  creditoId           String?
  credito             Credito? @relation(fields: [creditoId], references: [creditoId], onDelete: SetNull)
  usuarioId           String
  usuario             Usuario  @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  nome                String
  endereco            String
  geoLatitude         Float
  geoLongitude        Float
  raioValidacaoMetros Int      @default(50)
  areaM2              Float?
  tipo                String?
  status              ObraStatus @default(PLANEJAMENTO)
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  etapas              EtapaObra[]
  evidencias          EvidenciaEtapa[]
  leads               Lead[]

  @@index([usuarioId])
  @@index([creditoId])
  @@index([status])
  @@index([status, atualizadoEm])
  @@index([geoLatitude, geoLongitude])
}

enum ObraStatus {
  PLANEJAMENTO
  EM_EXECUCAO
  PAUSADA
  CONCLUIDA
  CANCELADA
}

// ── Etapas de Obra ────────────────────────────────────────────────────

model EtapaObra {
  etapaId             String   @id @default(uuid())
  obraId              String
  obra                Obra     @relation(fields: [obraId], references: [obraId], onDelete: Cascade)
  nome                String
  ordem               Int
  percentualObra      Float
  valorLiberacao      Float
  status              EtapaStatus @default(PLANEJADA)
  dataConclusaoPrevista DateTime?
  dataConclusaoReal   DateTime?
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  evidencias          EvidenciaEtapa[]

  @@unique([obraId, ordem])
  @@index([obraId])
  @@index([status])
  @@index([status, criadoEm])
}

enum EtapaStatus {
  PLANEJADA
  EM_EXECUCAO
  AGUARDANDO_VISTORIA
  REPROVADA
  CONCLUIDA
}

// ── Evidências de Etapa ───────────────────────────────────────────────

model EvidenciaEtapa {
  evidenciaId       String   @id @default(uuid())
  etapaId           String
  etapa             EtapaObra @relation(fields: [etapaId], references: [etapaId], onDelete: Cascade)
  obraId            String
  obra              Obra     @relation(fields: [obraId], references: [obraId], onDelete: Cascade)
  fotoUrl           String
  latCaptura        Float
  lngCaptura        Float
  accuracyMetros    Float?
  distanciaObra     Float?
  exifTimestamp     DateTime?
  fotoKey           String?
  validada          Boolean  @default(false)
  observacao        String?
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  @@index([etapaId])
  @@index([obraId])
  @@index([validada])
  @@index([validada, criadoEm])
}

// ── Liberações de Parcelas ────────────────────────────────────────────

model LiberacaoParcela {
  liberacaoId     String   @id @default(uuid())
  creditoId       String
  credito         Credito  @relation(fields: [creditoId], references: [creditoId], onDelete: Cascade)
  valor           Float
  status          LiberacaoStatus @default(PENDENTE)
  motivo          String?
  processadoEm    DateTime?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@index([creditoId])
  @@index([status])
}

enum LiberacaoStatus {
  PENDENTE
  PROCESSANDO
  CONCLUIDA
  FALHA
}

// ── Score de Construtibilidade ────────────────────────────────────────

model ScoreHistorico {
  scoreId     String   @id @default(uuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  score       Int
  motivo      String?
  criadoEm    DateTime @default(now())

  @@index([usuarioId])
  @@index([criadoEm])
}

// ── KYC Documents ──────────────────────────────────────────────────────

model KycDocumento {
  kycDocumentoId String   @id @default(uuid())
  usuarioId      String
  usuario        Usuario  @relation("KycDocumentos", fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  tipo           String   // RG, CNH, Selfie, Comprovante de Residência, etc.
  url            String   // S3 URL
  status         KycDocumentoStatus @default(PENDENTE)
  motivo_rejeicao String?
  analisadoPor   String?  // usuarioId of reviewer
  analisadoEm    DateTime?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  @@index([usuarioId])
  @@index([status])
  @@index([criadoEm])
}

enum KycDocumentoStatus {
  PENDENTE
  APROVADO
  REJEITADO
}

// ── Notificações ───────────────────────────────────────────────────

model Notificacao {
  notificacaoId String   @id @default(uuid())
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  tipo          TipoNotificacao
  titulo        String
  mensagem      String
  link          String?
  lida          Boolean  @default(false)
  lidoEm        DateTime?
  criadoEm      DateTime @default(now())

  @@index([usuarioId])
  @@index([lida])
  @@index([criadoEm])
}

enum TipoNotificacao {
  ETAPA_APROVADA
  ETAPA_REPROVADA
  PARCELA_LIBERADA
  PARCELA_FALHA
  CREDITO_APROVADO
  KYC_APROVADO
  KYC_REJEITADO
  OBRA_CRIADA
  SCORE_ATUALIZADO
  VISTORIA_PENDENTE
}

// ── Job Falhas ────────────────────────────────────────────────────

model JobFalha {
  jobFalhaId  String   @id @default(uuid())
  queue       String
  jobId       String
  payload     Json
  erro        String
  tentativas  Int
  criadoEm   DateTime @default(now())

  @@index([queue])
  @@index([criadoEm])
}

// ── Analytics ──────────────────────────────────────────────────────

model AnalyticsEvent {
  eventId    String   @id @default(uuid())
  usuarioId  String
  eventType  String
  metadata   Json?
  timestamp  DateTime @default(now())

  @@index([usuarioId])
  @@index([eventType])
  @@index([timestamp])
}

// ── Comercial / Leads ────────────────────────────────────────────────

model PipelineStage {
  stageId     String   @id @default(uuid())
  pipelineId  String
  pipeline    Pipeline @relation(fields: [pipelineId], references: [pipelineId], onDelete: Cascade)
  nome        String
  ordem       Int
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  leads       Lead[]

  @@unique([pipelineId, ordem])
  @@index([pipelineId])
}

model Pipeline {
  pipelineId  String   @id @default(uuid())
  nome        String
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  stages      PipelineStage[]

  @@index([criadoEm])
}

model Lead {
  leadId            String   @id @default(uuid())
  clienteNome       String
  clienteEmail      String
  clienteTelefone   String
  clienteCpf        String?
  fonte             String   // PARCEIRO, INDICACAO, WEBSITE, OFFLINE
  tipoObra          String   // residencial, comercial, industrial, reforma
  segmentoCliente   String   // NOVO, RETORNO, CONCORRENTE
  stageId           String
  stage             PipelineStage @relation(fields: [stageId], references: [stageId], onDelete: Restrict)
  obraId            String?
  obra              Obra?    @relation(fields: [obraId], references: [obraId], onDelete: SetNull)
  usuarioId         String
  usuario           Usuario  @relation("LeadsCreatedBy", fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  atividades        LeadActivity[]
  scoreHistorico    ConversionScore[]

  @@index([stageId])
  @@index([usuarioId])
  @@index([obraId])
  @@index([criadoEm])
}

model LeadActivity {
  leadActivityId String   @id @default(uuid())
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [leadId], onDelete: Cascade)
  usuarioId      String
  usuario        Usuario  @relation("LeadActivities", fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  tipo           String   // CALL, EMAIL, MEETING, PROPOSAL, VISIT, FOLLOW_UP, NOTE
  descricao      String
  criadoEm       DateTime @default(now())

  @@index([leadId])
  @@index([usuarioId])
  @@index([criadoEm])
}

model ConversionScore {
  scoreId              String   @id @default(uuid())
  leadId               String
  lead                 Lead     @relation(fields: [leadId], references: [leadId], onDelete: Cascade)
  scoreFinal           Int
  probabilidadeClosing Float
  dataEstimadaClosing  DateTime
  fonteScore           Int
  tipoObraScore        Int
  segmentoScore        Int
  engajamentoScore     Int
  historicoScore       Int
  criadoEm             DateTime @default(now())

  @@index([leadId])
  @@index([criadoEm])
}
