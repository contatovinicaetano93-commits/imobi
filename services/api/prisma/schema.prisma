// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Usuários ────────────────────────────────────────────────────────

model Usuario {
  usuarioId     String   @id @default(uuid())
  nome          String
  cpf           String   @unique
  email         String   @unique
  telefone      String
  avatarUrl     String?
  passwordHash  String
  tipo          UsuarioTipo @default(TOMADOR)
  comercialRole ComercialRole?
  kycStatus           KycStatus @default(PENDENTE)
  consentidoTermos    Boolean   @default(false)
  consentidoPrivacy   Boolean   @default(false)
  consentidoKyc       Boolean   @default(false)
  consentidoMarketing Boolean   @default(false)
  consentidoEm        DateTime?
  passwordResetToken    String?
  passwordResetExpires  DateTime?
  bloqueadoEm         DateTime?
  funcoesBloqueadas   String[]  @default([])
  preferenciasNotificacao Json?
  contaBanco              String?
  contaAgencia            String?
  contaNumero             String?
  contaPix                String?
  contaTitular            String?
  deletadoEm          DateTime?
  criadoEm            DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  sessoes       SessaoToken[]
  creditos       Credito[]
  obras          Obra[]
  scoreHistorico ScoreHistorico[]
  kycDocumentos KycDocumento[] @relation("KycDocumentos")
  notificacoes  Notificacao[]
  fcmTokens     UsuarioFcmToken[]
  etapaAuditLogs EtapaAuditLog[] @relation("EtapaAuditLogs")
  kycAuditLogs  KycAuditLog[] @relation("KycAuditLogs")
  leadsGerenciados Lead[] @relation("LeadUsuarios")
  mailingContatos MailingContato[]
  dueDiligences   DueDiligence[]
  documentos      Documento[]
  solicitacoes    SolicitacaoCredito[]
  votosComite     VotoComite[]
  lancamentos     LancamentoFinanceiro[]
  totp            UsuarioTotp?
  webhooks        WebhookEndpoint[]

  @@index([email])
  @@index([cpf])
  @@index([deletadoEm])
}

enum DocumentoTipo {
  CONTRATO
  GARANTIA
  MATRICULA
  ART
  ALVARA
  SEGURO
  PROCURACAO
  ESCRITURA
  HABITE_SE
  OUTROS
}

enum UsuarioTipo {
  TOMADOR
  GESTOR_OBRA
  ADMIN
  PARCEIRO
  GESTOR
  GESTOR_FUNDO
  ENGENHEIRO
  COMERCIAL
  CONSTRUTOR
}

enum KycStatus {
  PENDENTE
  EM_VERIFICACAO
  APROVADO
  REJEITADO
}

// ── Sessões ───────────────────────────────────────────────────────

model SessaoToken {
  sessionId     String    @id @default(uuid())
  usuarioId     String
  usuario       Usuario   @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  refreshToken  String    @unique
  expiresAt     DateTime
  revogadoEm    DateTime?
  criadoEm      DateTime  @default(now())
  ipAddress     String?
  userAgent     String?

  @@index([usuarioId])
}

model UsuarioFcmToken {
  usuarioId   String
  token       String
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuario     Usuario  @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)

  @@id([usuarioId, token])
  @@index([ativo])
  @@map("usuario_fcm_tokens")
}

// ── Créditos ──────────────────────────────────────────────────────

model Credito {
  creditoId       String    @id @default(uuid())
  usuarioId       String
  usuario         Usuario   @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  valorAprovado   Decimal   @db.Decimal(14, 2)
  valorLiberado   Decimal   @db.Decimal(14, 2)
  taxaMensal      Float     @default(0.0099)
  prazoMeses      Int
  status          CreditoStatus @default(ATIVO)
  dataAprovacao   DateTime  @default(now())
  dataVencimento  DateTime?
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt

  obras           Obra[]
  liberacoes      LiberacaoParcela[]
  lancamentos     LancamentoFinanceiro[]

  @@index([usuarioId])
  @@index([status])
  @@index([usuarioId, criadoEm])
}

enum CreditoStatus {
  ATIVO
  SUSPENSO
  VENCIDO
  QUITADO
}

// ── Obras ─────────────────────────────────────────────────────────

model Obra {
  obraId              String   @id @default(uuid())
  creditoId           String?
  credito             Credito? @relation(fields: [creditoId], references: [creditoId], onDelete: SetNull)
  usuarioId           String
  usuario             Usuario  @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  nome                String
  endereco            String
  geoLatitude         Float
  geoLongitude        Float
  raioValidacaoMetros Int      @default(50)
  areaM2              Float?
  tipo                String?
  status              ObraStatus @default(AGUARDANDO_HOMOLOGACAO)
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  etapas              EtapaObra[]
  evidencias          EvidenciaEtapa[]
  leads               Lead[]
  documentos          Documento[]

  @@index([usuarioId])
  @@index([creditoId])
  @@index([status])
}

enum ObraStatus {
  AGUARDANDO_HOMOLOGACAO
  PLANEJAMENTO
  EM_EXECUCAO
  PAUSADA
  CONCLUIDA
  CANCELADA
}

// ── Etapas de Obra ──────────────────────────────────────────────────

model EtapaObra {
  etapaId             String   @id @default(uuid())
  obraId              String
  obra                Obra     @relation(fields: [obraId], references: [obraId], onDelete: Cascade)
  nome                String
  ordem               Int
  percentualObra      Float
  valorLiberacao      Decimal  @db.Decimal(14, 2)
  status              EtapaStatus @default(PLANEJADA)
  dataConclusaoPrevista DateTime?
  dataConclusaoReal   DateTime?
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  evidencias          EvidenciaEtapa[]
  auditLogs           EtapaAuditLog[]

  @@unique([obraId, ordem])
  @@index([obraId])
  @@index([status])
  @@index([obraId, status])
}

enum EtapaStatus {
  PLANEJADA
  EM_EXECUCAO
  AGUARDANDO_VISTORIA
  REPROVADA
  CONCLUIDA
}

// ── Evidências de Etapa ─────────────────────────────────────────────

model EvidenciaEtapa {
  evidenciaId       String   @id @default(uuid())
  etapaId           String
  etapa             EtapaObra @relation(fields: [etapaId], references: [etapaId], onDelete: Cascade)
  obraId            String
  obra              Obra     @relation(fields: [obraId], references: [obraId], onDelete: Cascade)
  fotoUrl           String
  latCaptura        Float
  lngCaptura        Float
  accuracyMetros    Float?
  distanciaObra     Float?
  validada          Boolean  @default(false)
  observacao        String?
  deletadoEm        DateTime?
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  @@index([etapaId])
  @@index([obraId])
  @@index([validada])
  @@index([obraId, validada])
  @@index([deletadoEm])
}

// ── Liberações de Parcelas ──────────────────────────────────────────

model LiberacaoParcela {
  liberacaoId     String   @id @default(uuid())
  creditoId       String
  credito         Credito  @relation(fields: [creditoId], references: [creditoId], onDelete: Cascade)
  etapaId         String?
  valor           Decimal  @db.Decimal(14, 2)
  status          LiberacaoStatus @default(PENDENTE)
  motivo          String?
  referenciaPagamento String?
  processadoEm    DateTime?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@index([creditoId])
  @@index([etapaId])
  @@index([status])
}

enum LiberacaoStatus {
  PENDENTE
  AGUARDANDO_PAGAMENTO
  PROCESSANDO
  CONCLUIDA
  FALHA
}

// ── Score de Construtibilidade ──────────────────────────────────────

model ScoreHistorico {
  scoreId     String   @id @default(uuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  score       Int
  motivo      String?
  criadoEm    DateTime @default(now())

  @@index([usuarioId])
  @@index([criadoEm])
}

// ── KYC Documents ────────────────────────────────────────────────────

model KycDocumento {
  kycDocumentoId String   @id @default(uuid())
  usuarioId      String
  usuario        Usuario  @relation("KycDocumentos", fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  tipo           String
  url            String
  status         KycDocumentoStatus @default(PENDENTE)
  motivo_rejeicao String?
  analisadoPor   String?
  analisadoEm    DateTime?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
  auditLogs      KycAuditLog[]

  @@index([usuarioId])
  @@index([status])
  @@index([criadoEm])
}

enum KycDocumentoStatus {
  PENDENTE
  APROVADO
  REJEITADO
}

// ── Notificações ─────────────────────────────────────────────────

model Notificacao {
  notificacaoId String   @id @default(uuid())
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  tipo          TipoNotificacao
  titulo        String
  mensagem      String
  link          String?
  lida          Boolean  @default(false)
  lidoEm        DateTime?
  criadoEm      DateTime @default(now())

  @@index([usuarioId])
  @@index([lida])
  @@index([criadoEm])
  @@index([usuarioId, lida])
}

enum TipoNotificacao {
  ETAPA_APROVADA
  ETAPA_REPROVADA
  PARCELA_LIBERADA
  PARCELA_FALHA
  CREDITO_APROVADO
  KYC_APROVADO
  KYC_REJEITADO
  OBRA_CRIADA
  OBRA_HOMOLOGADA
  SCORE_ATUALIZADO
  VISTORIA_PENDENTE
  PARECER_SOLICITADO
  COMITE_DECISAO
}

// ── Auditoria de Etapas ───────────────────────────────────────────────

model EtapaAuditLog {
  auditId         String   @id @default(uuid())
  etapaId         String
  etapa           EtapaObra @relation(fields: [etapaId], references: [etapaId], onDelete: Cascade)
  acaoTipo        String
  usuarioId       String
  usuario         Usuario  @relation("EtapaAuditLogs", fields: [usuarioId], references: [usuarioId], onDelete: Restrict)
  observacoes     String?
  criadoEm        DateTime @default(now())

  @@index([etapaId])
  @@index([usuarioId])
  @@index([criadoEm])
}

// ── Auditoria de KYC ──────────────────────────────────────────────────

model KycAuditLog {
  auditId         String      @id @default(uuid())
  kycDocumentoId  String
  kyc             KycDocumento @relation(fields: [kycDocumentoId], references: [kycDocumentoId], onDelete: Cascade)
  acaoTipo        String
  usuarioId       String
  usuario         Usuario     @relation("KycAuditLogs", fields: [usuarioId], references: [usuarioId], onDelete: Restrict)
  motivo          String?
  criadoEm        DateTime @default(now())

  @@index([kycDocumentoId])
  @@index([usuarioId])
  @@index([criadoEm])
}

// ── Comercial: Leads & Pipeline ──────────────────────────────────────────

enum LeadFonte {
  WEBSITE
  INDICACAO
  MARKETPLACE
  CAMPANHA_DIGITAL
  OFFLINE
  PARCEIRO
}

enum LeadSegmento {
  NOVO
  RETORNO
  CONCORRENTE
}

enum LeadActivityTipo {
  CALL_OUTBOUND
  CALL_INBOUND
  EMAIL_SENT
  EMAIL_RECEIVED
  MEETING_SCHEDULED
  MEETING_COMPLETED
  PROPOSAL_SENT
  DOCUMENT_REQUESTED
  PAYMENT_RECEIVED
  STAGE_CHANGED
  NOTE_ADDED
  FOLLOW_UP_SET
}

enum ComercialRole {
  GERENTE_VENDAS
  REPRESENTANTE
}

model PipelineStage {
  stageId         String   @id @default(uuid())
  nome            String   @unique
  ordem           Int      @unique
  descricao       String?
  corHex          String   @default("#999999")
  taxaConversao   Float    @default(0.0)
  diasMedioStage  Int      @default(7)

  leads           Lead[]

  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@index([ordem])
}

model Lead {
  leadId              String   @id @default(uuid())
  obraId              String?
  obra                Obra?    @relation(fields: [obraId], references: [obraId], onDelete: SetNull)
  usuarioId           String?
  usuario             Usuario? @relation("LeadUsuarios", fields: [usuarioId], references: [usuarioId], onDelete: SetNull)
  atribuidoEm         DateTime?

  clienteNome         String
  clienteEmail        String
  clienteTelefone     String
  clienteCpf          String?

  stageId             String
  stage               PipelineStage @relation(fields: [stageId], references: [stageId], onDelete: Restrict)

  fonte               LeadFonte     @default(WEBSITE)
  tipoObra            String?
  segmentoCliente     LeadSegmento  @default(NOVO)

  condicoes           String?
  proximoAcompanhamento DateTime?
  statusUltimo        String?

  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt
  convertidoEm        DateTime?

  scoreHistorico      ConversionScore[]
  atividades          LeadActivity[]

  @@index([obraId])
  @@index([usuarioId])
  @@index([stageId])
  @@index([fonte])
  @@index([segmentoCliente])
  @@index([criadoEm])
  @@index([convertidoEm])
}

model ConversionScore {
  scoreId             String   @id @default(uuid())
  leadId              String
  lead                Lead     @relation(fields: [leadId], references: [leadId], onDelete: Cascade)

  scoreFinal          Float
  probabilidadeClosing Float
  dataEstimadaClosing DateTime?

  fonteScore          Float    @default(0.0)
  tipoObraScore       Float    @default(0.0)
  segmentoScore       Float    @default(0.0)
  engajamentoScore    Float    @default(0.0)
  historicoScore      Float    @default(0.0)

  versaoAlgoritmo     String   @default("v1")

  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@index([leadId])
  @@index([scoreFinal])
  @@index([atualizadoEm])
}

model LeadActivity {
  atividadeId     String   @id @default(uuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [leadId], onDelete: Cascade)

  tipo            LeadActivityTipo
  descricao       String
  usuarioId       String

  criadoEm        DateTime @default(now())

  @@index([leadId])
  @@index([tipo])
  @@index([criadoEm])
}

// ── Parceiros: Mailing ─────────────────────────────────────────────────

model MailingContato {
  id        String        @id @default(uuid())
  usuarioId String
  usuario   Usuario       @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  nome      String
  email     String
  telefone  String?
  status    MailingStatus @default(NOVO)
  criadoEm  DateTime      @default(now())

  @@index([usuarioId])
}

enum MailingStatus {
  NOVO
  CONTATADO
  CONVERTIDO
}

// ── Due Diligence ───────────────────────────────────────────────────────

model DueDiligence {
  id                    String   @id @default(uuid())
  gestor                Usuario  @relation(fields: [gestorId], references: [usuarioId])
  gestorId              String
  nomeEmpreendimento    String
  tipologia             String?
  endereco              String?
  cidade                String?
  uf                    String?
  totalUnidades         Int?
  areaTotal             Float?
  dataEntregaPrevista   DateTime?
  nomeIncorporadora     String?
  cnpjIncorporadora     String?
  modeloAmortizacao     String?
  totalCarteira         Decimal? @db.Decimal(14, 2)
  totalAReceber         Decimal? @db.Decimal(14, 2)
  estruturaSocietaria   String?
  payload               Json
  status                DueDiligenceStatus @default(RASCUNHO)
  criadoEm              DateTime @default(now())
  atualizadoEm          DateTime @updatedAt

  @@index([gestorId])
  @@index([status])
}

enum DueDiligenceStatus {
  RASCUNHO
  ENVIADO
  EM_ANALISE
  APROVADO
  REPROVADO
}

// ── Documentos ───────────────────────────────────────────────────────────

model Documento {
  documentoId  String        @id @default(uuid())
  obraId       String?
  usuarioId    String
  tipo         DocumentoTipo @default(OUTROS)
  nome         String
  url          String
  mimeType     String        @default("application/pdf")
  tamanhoBytes Int?
  descricao    String?
  vencimento   DateTime?
  criadoEm    DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt

  obra    Obra?   @relation(fields: [obraId], references: [obraId])
  usuario Usuario @relation(fields: [usuarioId], references: [usuarioId])

  @@index([usuarioId])
  @@index([obraId, criadoEm])
  @@map("documentos")
}

// ── Comitê Digital ────────────────────────────────────────────────────────────

model SolicitacaoCredito {
  solicitacaoId   String             @id @default(uuid())
  usuarioId       String
  usuario         Usuario            @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  obraId          String?

  valorSolicitado Decimal  @db.Decimal(14, 2)
  prazoMeses      Int
  taxaMensal      Float
  finalidade      String
  garantias       String?
  observacoes     String?

  // Snapshot da simulação para o dossiê
  vgv             Decimal? @db.Decimal(14, 2)
  ltv             Float?
  custoObra       Decimal? @db.Decimal(14, 2)
  ratingCalculado String?            // A/B/C/D

  status          SolicitacaoStatus  @default(PENDENTE)
  comite          ComiteDigital?

  criadoEm        DateTime           @default(now())
  atualizadoEm    DateTime           @updatedAt

  @@index([usuarioId])
  @@index([status])
  @@map("solicitacoes_credito")
}

enum SolicitacaoStatus {
  PENDENTE
  EM_COMITE
  APROVADA
  AJUSTADA
  REPROVADA
  CANCELADA
}

model ComiteDigital {
  comiteId        String         @id @default(uuid())
  solicitacaoId   String         @unique
  solicitacao     SolicitacaoCredito @relation(fields: [solicitacaoId], references: [solicitacaoId], onDelete: Cascade)

  parecerTecnico  String?
  parecerEngId    String?
  parecerEm       DateTime?

  status          ComiteStatus   @default(ABERTO)
  decisao         ComiteDecisao?
  decisaoMotivo   String?
  decisaoEm       DateTime?

  votos           VotoComite[]

  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt

  @@index([status])
  @@map("comites_digitais")
}

enum ComiteStatus {
  ABERTO
  EM_VOTACAO
  ENCERRADO
}

enum ComiteDecisao {
  APROVADO
  AJUSTADO
  REPROVADO
}

model VotoComite {
  votoId        String        @id @default(uuid())
  comiteId      String
  comite        ComiteDigital @relation(fields: [comiteId], references: [comiteId], onDelete: Cascade)
  votanteId     String
  votante       Usuario       @relation(fields: [votanteId], references: [usuarioId], onDelete: Cascade)
  voto          VotoDecisao
  justificativa String?
  condicoes     String?
  criadoEm      DateTime      @default(now())

  @@unique([comiteId, votanteId])
  @@index([comiteId])
  @@map("votos_comite")
}

enum VotoDecisao {
  APROVAR
  AJUSTAR
  REPROVAR
}

// ── Marketplace ───────────────────────────────────────────────────────────

enum FornecedorTipo {
  MATERIAL_CONSTRUCAO
  MAO_DE_OBRA
  EQUIPAMENTO
  PROJETO_ARQUITETURA
  ENGENHARIA
  OUTROS
}

model Fornecedor {
  fornecedorId    String          @id @default(uuid())
  nome            String
  tipo            FornecedorTipo
  descricao       String?
  website         String?
  telefone        String?
  email           String?
  endereco        String?
  uf              String?
  cidade          String?
  geoLatitude     Float?
  geoLongitude    Float?
  avaliacaoMedia  Float           @default(0.0)
  totalAvaliacoes Int             @default(0)
  ativo           Boolean         @default(true)
  criadoEm        DateTime        @default(now())
  atualizadoEm    DateTime        @updatedAt

  avaliacoes      AvaliacaoFornecedor[]

  @@index([tipo])
  @@index([uf])
  @@index([ativo])
  @@map("fornecedores")
}

model AvaliacaoFornecedor {
  avaliacaoId  String     @id @default(uuid())
  fornecedorId String
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [fornecedorId], onDelete: Cascade)
  usuarioId    String
  nota         Int
  comentario   String?
  criadoEm     DateTime   @default(now())

  @@unique([fornecedorId, usuarioId])
  @@index([fornecedorId])
  @@map("avaliacoes_fornecedor")
}

// ── Ledger Imutável ───────────────────────────────────────────────────────────
// Registro append-only de toda movimentação financeira. Nunca deletar/atualizar.

model LancamentoFinanceiro {
  lancamentoId   String              @id @default(uuid())
  tipo           LancamentoTipo
  categoria      LancamentoCategoria
  valor          Decimal             @db.Decimal(14, 2)
  moeda          String              @default("BRL")
  creditoId      String?
  liberacaoId    String?             @unique
  usuarioId      String
  descricao      String?
  metadata       Json?
  idempotencyKey String?             @unique
  criadoEm       DateTime            @default(now())

  credito        Credito?            @relation(fields: [creditoId], references: [creditoId], onDelete: Restrict)
  usuario        Usuario             @relation(fields: [usuarioId], references: [usuarioId], onDelete: Restrict)

  @@index([creditoId, criadoEm])
  @@index([usuarioId, criadoEm])
  @@map("lancamentos_financeiros")
}

enum LancamentoTipo {
  CREDITO
  DEBITO
}

enum LancamentoCategoria {
  LIBERACAO_PARCELA
  ESTORNO_LIBERACAO
  TAXA_GESTAO
  AJUSTE_MANUAL
}

// ── Idempotência ──────────────────────────────────────────────────────────────

model IdempotencyRecord {
  key          String   @id
  endpoint     String
  statusCode   Int
  responseBody Json
  criadoEm     DateTime @default(now())
  expiraEm     DateTime

  @@index([expiraEm])
  @@map("idempotency_records")
}

// ── Outbox Transacional ───────────────────────────────────────────────────────
// Garante entrega de eventos mesmo se o servidor cair após o commit.

model OutboxEvent {
  eventId      String      @id @default(uuid())
  tipo         String
  payload      Json
  status       OutboxStatus @default(PENDENTE)
  tentativas   Int          @default(0)
  erro         String?
  processadoEm DateTime?
  criadoEm     DateTime    @default(now())
  agendadoPara DateTime    @default(now())

  @@index([status, agendadoPara])
  @@map("outbox_events")
}

enum OutboxStatus {
  PENDENTE
  PROCESSANDO
  CONCLUIDO
  FALHA
}

// ── 2FA / TOTP ────────────────────────────────────────────────────────────────

model UsuarioTotp {
  totpId          String    @id @default(uuid())
  usuarioId       String    @unique
  secretCrypto    String
  ativo           Boolean   @default(false)
  ativadoEm       DateTime?
  backupCodes     String[]
  criadoEm        DateTime  @default(now())

  usuario         Usuario   @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)

  @@map("usuario_totp")
}

// ── Webhooks SaaS ──────────────────────────────────────────────────────────────

model WebhookEndpoint {
  webhookId    String    @id @default(uuid())
  usuarioId    String
  url          String
  secret       String
  eventos      String[]
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  usuario      Usuario   @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([usuarioId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  deliveryId      String    @id @default(uuid())
  webhookId       String
  evento          String
  payload         Json
  statusCode      Int?
  tentativas      Int       @default(0)
  sucesso         Boolean   @default(false)
  erro            String?
  criadoEm        DateTime  @default(now())
  ultimaTentativa DateTime?

  webhook         WebhookEndpoint @relation(fields: [webhookId], references: [webhookId], onDelete: Cascade)

  @@index([webhookId, criadoEm])
  @@index([sucesso])
  @@map("webhook_deliveries")
}

// ── Audit Log Financeiro ──────────────────────────────────────────────────────
// Rastreabilidade de toda ação financeira e administrativa.

model AuditLog {
  auditId    String   @id @default(uuid())
  acao       String
  entidade   String
  entidadeId String
  usuarioId  String?
  ipAddress  String?
  metadata   Json?
  criadoEm   DateTime @default(now())

  @@index([entidade, entidadeId])
  @@index([usuarioId])
  @@index([acao])
  @@index([criadoEm])
  @@map("audit_logs")
}
