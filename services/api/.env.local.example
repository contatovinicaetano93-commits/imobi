# Copie para services/api/.env.local
# cp services/api/.env.local.example services/api/.env.local
#
# Se existir services/api/.env com DATABASE_URL antigo, .env.local tem prioridade
# (env-loader.ts). Alternativa: remova DATABASE_URL do .env.

NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000

# Docker local (pnpm db:setup)
DATABASE_URL=postgresql://imobi_user:imobi_secure_password_123@localhost:5432/imobi_development
REDIS_HOST=localhost
REDIS_PORT=6379

# Mesmo valor em apps/web/.env.local (JWT_SECRET)
JWT_SECRET=dev-jwt-secret-minimo-32-caracteres-imobi
ENCRYPTION_KEY=dev-encryption-key-minimo-32-chars

# KYC local sem S3 — arquivos em services/api/uploads/
# ENABLE_S3_STORAGE=true
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

CORS_ORIGIN=http://localhost:3000,http://localhost:3001
