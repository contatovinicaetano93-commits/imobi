# Test Environment Variables
# Used for E2E tests via: NODE_ENV=test npm test

NODE_ENV=test
JWT_SECRET=dev_secret_64_chars_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Database (local PostgreSQL)
DATABASE_URL=postgresql://imobi_user:imobi_secure_password_123@localhost:5432/imobi_development?schema=public

# Redis (local)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Email (mocked in test mode)
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025

# Firebase (mocked in test mode - not required)
# Uses defaults: project_id=mock-project, client_email=mock@example.com, private_key=mock-key

# S3 (mocked in test mode)
# Uses local defaults: bucket=local-dev-bucket, region=us-east-1

# CORS (for testing from local frontend)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# API Port
API_PORT=4000
