# Test Environment
NODE_ENV=test
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Database (SQLite in-memory for tests would be ideal, but using PostgreSQL test db)
DATABASE_URL=postgresql://imbobi:senha@localhost:5432/imbobi_test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT - test secret
JWT_SECRET=test_secret_key_that_is_long_enough_for_testing_purposes_1234567890
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 (dummy values for tests)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test_key
AWS_SECRET_ACCESS_KEY=test_secret
S3_BUCKET=test-bucket

# Email (dummy values)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test
SMTP_PASS=test
SMTP_FROM=test@test.com
APP_URL=http://localhost:3000

# External APIs (dummy values)
UNICO_API_KEY=test_key
SERPRO_TOKEN=test_token
FIREBASE_PROJECT_ID=test_project
FIREBASE_PRIVATE_KEY=test_key
FIREBASE_CLIENT_EMAIL=test@test.com
