# Test Environment Variables
# Used for E2E tests via: NODE_ENV=test npm test

NODE_ENV=test
JWT_SECRET=test-jwt-secret-key-for-testing-purposes-only

# Database (local PostgreSQL)
DATABASE_URL=postgresql://postgres:test@localhost:5432/imobi_test

# Redis (local)
REDIS_URL=redis://localhost:6379

# Email (mocked in test mode)
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025

# Firebase (mocked in test mode - not required)
# Uses defaults: project_id=mock-project, client_email=mock@example.com, private_key=mock-key

# S3 (mocked in test mode)
# Uses local defaults: bucket=local-dev-bucket, region=us-east-1

# CORS (for testing from local frontend)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# API Port
API_PORT=4000
