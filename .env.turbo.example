# Turborepo Remote Caching Configuration
# Copy this file to .env.turbo and fill in the appropriate values

# Option 1: Vercel Remote Cache (Recommended for teams)
# 1. Run: turbo link
# 2. This will authenticate with your Vercel account and enable remote caching
# No environment variables needed for Vercel - authentication is handled by turbo link

# Option 2: Self-hosted Turborepo Remote Cache
# Set these variables to use a self-hosted cache server
# TURBO_REMOTE_CACHE_SERVER=<your-cache-server-url>
# TURBO_REMOTE_CACHE_TOKEN=<your-cache-token>

# Example for self-hosted setup:
# TURBO_REMOTE_CACHE_SERVER=https://turbo-cache.example.com
# TURBO_REMOTE_CACHE_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Option 3: Local-only caching (default, no remote cache)
# Leave all variables unset to use only local cache (not recommended for teams)

# Enable Turbo verbose logging (optional)
# TURBO_LOG_ORDER=stream
# TURBO_LOG_LEVEL=debug
