{
  "name": "@imbobi/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:preview": "eas build --profile preview",
    "build:preview:ios": "eas build --platform ios --profile preview",
    "build:preview:android": "eas build --platform android --profile preview",
    "build:production": "eas build --profile production",
    "build:production:ios": "eas build --platform ios --profile production",
    "build:production:android": "eas build --platform android --profile production",
    "build:list": "eas build:list",
    "submit:production": "eas submit --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "update:ios": "eas update --platform ios",
    "update:android": "eas update --platform android",
    "update:all": "eas update",
    "credentials": "eas credentials",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.6.0",
    "@imbobi/core": "workspace:*",
    "@imbobi/schemas": "workspace:*",
    "@react-native-async-storage/async-storage": "1.23.0",
    "@react-navigation/native": "^6.0.0",
    "expo": "~51.0.0",
    "expo-camera": "~15.0.0",
    "expo-file-system": "~17.0.0",
    "expo-haptics": "~13.0.0",
    "expo-image-picker": "~15.0.0",
    "expo-location": "~17.0.0",
    "expo-media-library": "~15.0.0",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "react": "18.2.0",
    "react-hook-form": "^7.52.0",
    "react-native": "0.74.0",
    "react-native-maps": "1.14.0",
    "react-native-safe-area-context": "4.10.1",
    "react-native-screens": "3.31.1",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.0",
    "typescript": "^5.5.0"
  }
}
