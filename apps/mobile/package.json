{
  "name": "@imbobi/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "dev": "expo start",
    "dev:clear": "expo start --clear",
    "dev:device": "node ./scripts/start-device.mjs",
    "dev:go": "node ./scripts/start-cloudflare.mjs",
    "dev:cf": "node ./scripts/start-cloudflare.mjs",
    "dev:hotspot": "node ./scripts/start-hotspot.mjs",
    "dev:tunnel": "node ./scripts/start-tunnel.mjs",
    "dev:ngrok": "node ./scripts/start-tunnel.mjs",
    "dev:kill": "node ./scripts/kill-expo-ports.mjs",
    "dev:reset": "node ./scripts/kill-expo-ports.mjs && node ./scripts/clear-metro-cache.mjs && node ./scripts/ensure-assets.mjs",
    "dev:reset-ngrok": "node ./scripts/reset-ngrok.mjs",
    "dev:lan": "expo start --lan --port 8081",
    "dev:offline": "expo start --offline --clear --port 8081",
    "dev:reset-cert": "node ./scripts/reset-expo-cert.mjs && expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:preview": "eas build --profile preview",
    "build:production": "eas build --profile production",
    "lint": "eslint app --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^3.6.0",
    "@imbobi/core": "workspace:*",
    "@imbobi/schemas": "workspace:*",
    "@react-native-community/slider": "^5.0.1",
    "expo": "~54.0.35",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "react": "19.1.0",
    "react-hook-form": "^7.79.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-worklets": "~0.5.1",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/ngrok": "^4.1.0",
    "@types/node": "^20.19.43",
    "@types/react": "~19.1.17",
    "typescript": "^5.5.0"
  }
}
