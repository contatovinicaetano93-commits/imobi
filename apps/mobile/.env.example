# Expo Mobile App Configuration

# API URL - Backend API endpoint
# Simulator/emulator on same machine:
# EXPO_PUBLIC_API_URL=http://localhost:4000
#
# Physical device (same Wi-Fi as dev PC — use your PC's LAN IPv4):
# EXPO_PUBLIC_API_URL=http://192.168.x.x:4000
#
# Staging: https://api-staging.imbobi.com.br
# Production: https://api.imbobi.com.br
EXPO_PUBLIC_API_URL=http://localhost:4000

# EAS Project ID (for building with Expo Application Services)
# Get from https://expo.dev/accounts/[your-account]/projects/[project-name]/settings
EAS_PROJECT_ID=your_eas_project_id_here
