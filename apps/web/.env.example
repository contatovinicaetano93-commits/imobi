# ── Next.js Web Frontend ───────────────────────────
# API Backend URL (must match API server CORS_ORIGIN)
# For Vercel: Use production API URL (e.g., https://api.yourdomain.com)
NEXT_PUBLIC_API_URL=http://localhost:4000

# AWS S3 Configuration
# S3 bucket name for storing build artifacts and assets
NEXT_PUBLIC_S3_BUCKET=imbobi-prod

# Sentry (error tracking) - Optional
# NEXT_PUBLIC_SENTRY_DSN=

# Environment
# For Vercel production: production
NODE_ENV=development
