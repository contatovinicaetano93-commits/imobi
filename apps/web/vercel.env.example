# ── Vercel Environment Variables ───────────────────────────
# These are the environment variables you need to set in Vercel Dashboard
# for the web frontend deployment.
#
# IMPORTANT: Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Do NOT put secrets here — use Vercel's encrypted secret storage.

# ── PUBLIC VARIABLES (Safe to expose in browser) ────────────────

# Production API Backend URL
# Development: http://localhost:4000
# Staging: https://api-staging.yourdomain.com
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# AWS S3 Bucket Name
# Must match the S3 bucket used by the API service
NEXT_PUBLIC_S3_BUCKET=imbobi-prod

# Optional: Sentry error tracking DSN (public)
# Get this from: https://sentry.io/settings/
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/123456

# ── PRIVATE VARIABLES (Stored securely in Vercel, not sent to browser) ────────────────

# Next.js environment
NODE_ENV=production

# ── NOTES ────────────────────────────────────────────────────
# 1. Set these in Vercel Dashboard:
#    - Go to Settings → Environment Variables
#    - Add each variable with the appropriate value
#
# 2. For NEXT_PUBLIC_API_URL:
#    - Staging: https://api-staging.yourdomain.com
#    - Production: https://api.yourdomain.com
#    - Must match the API server's CORS_ORIGIN setting
#
# 3. For NEXT_PUBLIC_S3_BUCKET:
#    - Should point to the same S3 bucket as your API
#    - Images are stored and retrieved from this bucket
#
# 4. Preview Deployments:
#    - You may want different API URL for staging/preview
#    - Use Vercel's branch-specific environment variables for this
#
# 5. Sensitive Data:
#    - Never commit .env.local to git
#    - Use Vercel Dashboard for secret management
#    - For local development: copy .env.example to .env.local
