# IMOBI Web — desenvolvimento local (copie para .env.local)
# cp apps/web/.env.local.example apps/web/.env.local

# API staging (Render) — use enquanto Claude Code nao roda API local
NEXT_PUBLIC_API_URL=https://imobi-api-staging.onrender.com

# Necessario para middleware validar JWT apos login (mesmo valor da API)
# Obtenha do .env da API staging ou do time — NAO commitar valor real
JWT_SECRET=substituir_pelo_jwt_secret_da_api_staging

# App
NEXT_PUBLIC_APP_NAME=IMOBI
NODE_ENV=development

# Sentry (opcional em dev)
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_RELEASE=dev
