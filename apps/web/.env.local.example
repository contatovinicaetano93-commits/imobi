# IMOBI Web — desenvolvimento local (copie para .env.local)
# cp apps/web/.env.local.example apps/web/.env.local

# API local (use com `pnpm dev` — API na porta 4000):
NEXT_PUBLIC_API_URL=http://localhost:4000

# API staging (Render) — se não rodar API local:
# NEXT_PUBLIC_API_URL=https://imobi-api-staging.onrender.com

# Mesmo JWT_SECRET de services/api/.env.local
JWT_SECRET=dev-jwt-secret-minimo-32-caracteres-imobi

# App
NEXT_PUBLIC_APP_NAME=IMOBI
NODE_ENV=development

# Sentry (opcional em dev)
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_RELEASE=dev
