# DEPRECATED — Imobi usa Vercel + Render apenas. Ver docs/DEPLOY_STACK.md
# Mantido só para referência; não conectar novo deploy Railway.

[build]
builder = "RAILPACK"
buildCommand = "pnpm run build:api"
watchPatterns = ["services/api/**", "packages/**"]

[deploy]
startCommand = "pnpm --filter @imbobi/api start"
healthcheckPath = "/api/v1/health"
restartPolicyType = "ON_FAILURE"
