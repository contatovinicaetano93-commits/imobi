## 📋 CODE PATTERNS

### NestJS Service (Backend)

```typescript
@Injectable()
export class ObraService {
  constructor(
    private db: PrismaService,
    private cache: RedisService,
    private logger: LoggerService,
    private queue: Queue,  // BullMQ for async
  ) {}

  async getObra(id: string, usuarioId: string) {
    try {
      // 1. Check cache (Redis)
      const cached = await this.cache.get(`obra:${id}`);
      if (cached) return JSON.parse(cached);

      // 2. Query database
      const obra = await this.db.obra.findUnique({
        where: { id },
        include: { etapas: true, creditos: true },
      });

      // 3. Validate access
      if (!obra) throw new NotFoundException('Obra not found');
      if (obra.usuarioId !== usuarioId) throw new ForbiddenException();

      // 4. Cache result
      await this.cache.set(
        `obra:${id}`,
        JSON.stringify(obra),
        'EX',
        600  // 10 min TTL
      );

      // 5. Log
      this.logger.debug('Obra fetched', { obraId: id, cached: false });

      return obra;
    } catch (error) {
      this.logger.error('Failed to fetch obra', { obraId: id, error });
      throw error;
    }
  }

  // Async operations ALWAYS use BullMQ
  async aprovarEtapa(etapaId: string, managerId: string) {
    await this.queue.add('etapa-approval', {
      etapaId,
      managerId,
      timestamp: new Date(),
    }, {
      attempts: 3,
      backoff: { type: 'exponential', delay: 1000 },
    });
  }
}
```

### React Component (Frontend)

```typescript
import { obraSchema } from '@imbobi/schemas';
import { useApi } from '@imbobi/core';

type ObraCardProps = {
  obra: z.infer<typeof obraSchema>;
  onSelect?: (obra) => void;
};

export function ObraCard({ obra, onSelect }: ObraCardProps) {
  const { data: detalhes, loading, error } = useApi(
    () => fetch(`/api/obras/${obra.id}`),
    [obra.id]
  );

  if (loading) return <Skeleton className="h-40 w-full" />;
  if (error) return <ErrorAlert message={error.message} />;

  return (
    <Card
      className="cursor-pointer hover:shadow-lg"
      onClick={() => onSelect?.(obra)}
    >
      <h3 className="font-bold">{obra.nome}</h3>
      <p className="text-sm text-gray-600">{detalhes?.endereco}</p>
    </Card>
  );
}
```

### Zod Schema (Shared Validation)

```typescript
// packages/@imbobi/schemas/src/obra.ts

export const obraSchema = z.object({
  id: z.string().uuid(),
  nome: z.string().min(3).max(255),
  endereco: z.string(),
  status: z.enum(['CRIADA', 'APROVADA', 'ATIVA', 'CONCLUIDA', 'CANCELADA']),
  latitude: z.number().min(-90).max(90),
  longitude: z.number().min(-180).max(180),
  dataInicio: z.date(),
  dataConclusao: z.date().optional(),
  usuarioId: z.string().uuid(),
  criadoEm: z.date(),
});

export type Obra = z.infer<typeof obraSchema>;
```

