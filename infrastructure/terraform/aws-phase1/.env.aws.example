# AWS Credentials for Phase 1 Deployment
# IMPORTANT: Never commit this file with actual credentials!
# Copy to .env.aws and fill with your actual credentials

# AWS IAM User access key (starts with AKIA)
AWS_ACCESS_KEY_ID=AKIA_YOUR_ACCESS_KEY_HERE

# AWS IAM User secret access key
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# AWS Region for deployment
AWS_REGION=us-east-1

# Required permissions for this IAM User:
# - EC2 (VPC, Subnets, Security Groups)
# - RDS (Create DB instances, parameter groups, subnet groups)
# - ElastiCache (Create clusters, subnet groups)
# - SES (Email service configuration)
# - SNS (Notifications)
# - CloudWatch (Logs and Alarms)
# - CloudFormation (for Terraform state management)
