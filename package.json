{
  "name": "imbobi",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter @imbobi/schemas build && pnpm --filter @imbobi/core build && pnpm --filter @imbobi/db generate && pnpm --filter @imbobi/web dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e:local": "node scripts/run-e2e-local.mjs",
    "test:panel-nav": "pnpm --filter @imbobi/web exec tsx lib/panel-navigation.test.ts",
    "db:generate": "pnpm --filter @imbobi/db run generate",
    "db:migrate": "pnpm --filter @imbobi/db run migrate:dev",
    "db:migrate:deploy": "pnpm --filter @imbobi/db run migrate:deploy",
    "db:studio": "pnpm --filter @imbobi/db run studio",
    "seed:dev": "pnpm --filter @imbobi/db run seed:dev",
    "vercel:env:push": "node scripts/vercel-push-env.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "tsx": "^4.22.0",
    "turbo": "^2.9.18",
    "typescript": "^5.5.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "pnpm": {
    "overrides": {
      "fastify": "4.29.1",
      "@fastify/static": "7.0.4",
      "react": "^18.3.0",
      "react-dom": "^18.3.0"
    }
  }
}
