{
  "name": "imbobi",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@imbobi/api",
    "start": "pnpm --filter @imbobi/api start",
    "dev": "turbo run dev --filter=@imbobi/web --filter=@imbobi/api",
    "dev:stack": "turbo run dev --filter=@imbobi/web --filter=@imbobi/api",
    "dev:all": "turbo run dev",
    "dev:api": "pnpm --filter @imbobi/api dev",
    "dev:web": "pnpm --filter @imbobi/web dev",
    "dev:device": "pnpm --filter @imbobi/mobile dev:device",
    "dev:kill": "pnpm --filter @imbobi/mobile dev:kill",
    "dev:go": "pnpm --filter @imbobi/mobile dev:go",
    "dev:reset-ngrok": "pnpm --filter @imbobi/mobile dev:reset-ngrok",
    "mobile:dev": "pnpm --filter @imbobi/mobile dev",
    "mobile:dev:device": "pnpm --filter @imbobi/mobile dev:device",
    "mobile:dev:tunnel": "pnpm --filter @imbobi/mobile dev:tunnel",
    "mobile:dev:go": "pnpm --filter @imbobi/mobile dev:go",
    "mobile:dev:hotspot": "pnpm --filter @imbobi/mobile dev:hotspot",
    "mobile:dev:kill": "pnpm --filter @imbobi/mobile dev:kill",
    "mobile:dev:reset": "pnpm --filter @imbobi/mobile dev:reset",
    "mobile:dev:reset-ngrok": "pnpm --filter @imbobi/mobile dev:reset-ngrok",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "validate:schemas": "tsx scripts/validate-schema-sync.ts",
    "db:generate": "pnpm --filter @imbobi/api run prisma:generate",
    "db:migrate": "pnpm --filter @imbobi/api prisma:migrate:dev",
    "db:studio": "pnpm --filter @imbobi/api prisma studio",
    "docker:up": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/docker-up.ps1",
    "setup:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-dev.ps1",
    "seed:dev": "pnpm --filter @imbobi/api seed:dev"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "tsx": "^4.22.0",
    "turbo": "^2.9.18",
    "typescript": "^5.5.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "pnpm": {
    "overrides": {
      "fastify": "4.29.1",
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  }
}
