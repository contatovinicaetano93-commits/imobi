{
  "name": "imbobi",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @imbobi/api prisma generate",
    "db:migrate": "pnpm --filter @imbobi/api prisma migrate dev",
    "db:studio": "pnpm --filter @imbobi/api prisma studio"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3",
    "@types/react-dom": "^18.3",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "dependencies": {
    "@react-native-community/slider": "^5.2.0",
    "class-transformer": "^0.5.1"
  }
}
