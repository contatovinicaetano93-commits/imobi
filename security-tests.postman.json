{
  "info": {
    "name": "imbobi Security Validation Tests",
    "description": "Comprehensive security tests for OWASP Top 20 vulnerabilities",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. CSRF Protection",
      "item": [
        {
          "name": "Get CSRF Token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/csrf-token",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "csrf-token"]
            }
          }
        },
        {
          "name": "POST without CSRF (should fail)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"test@test.com\",\"senha\":\"pass\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Rate Limiting",
      "item": [
        {
          "name": "Rapid Login Attempts (10+ requests)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"nonexistent@test.com\",\"senha\":\"wrongpass\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Execute multiple times. Should get 429 after 10 attempts/min"
          }
        },
        {
          "name": "Check Rate Limit Response Headers",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"test@test.com\",\"senha\":\"pass\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "When rate limited, should have Retry-After header"
          }
        }
      ]
    },
    {
      "name": "3. Encryption & Data Exposure",
      "item": [
        {
          "name": "Register User (check for exposed data)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\":\"Test User\",\"email\":\"test-{{$timestamp}}@test.com\",\"cpf\":\"11144477735\",\"telefone\":\"11999999999\",\"senha\":\"TestPass123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/registrar",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "auth", "registrar"]
            },
            "description": "Should NOT contain: password, senha, plaintext"
          }
        },
        {
          "name": "Verify HttpOnly Cookie",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\":\"Cookie Test\",\"email\":\"cookie-{{$timestamp}}@test.com\",\"cpf\":\"11144477735\",\"telefone\":\"11999999999\",\"senha\":\"TestPass123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/registrar",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "auth", "registrar"]
            },
            "description": "Set-Cookie header should include HttpOnly flag"
          }
        }
      ]
    },
    {
      "name": "4. IDOR Prevention",
      "item": [
        {
          "name": "Create User 1",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\":\"User 1\",\"email\":\"user1-{{$timestamp}}@test.com\",\"cpf\":\"11144477735\",\"telefone\":\"11999999999\",\"senha\":\"TestPass123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/registrar",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "auth", "registrar"]
            }
          }
        },
        {
          "name": "Create User 2",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\":\"User 2\",\"email\":\"user2-{{$timestamp}}@test.com\",\"cpf\":\"12345678902\",\"telefone\":\"11999999998\",\"senha\":\"TestPass123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/registrar",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "auth", "registrar"]
            }
          }
        },
        {
          "name": "User 1 Creates Obra",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{user1_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"titulo\":\"Test Obra\",\"descricao\":\"IDOR Test\",\"latitude\":-23.5505,\"longitude\":-46.6333}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/obras",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "obras"]
            }
          }
        },
        {
          "name": "User 2 Tries to Access User 1's Obra (should fail)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user2_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/obras/{{obra_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "obras", "{{obra_id}}"]
            },
            "description": "Should return 403 Forbidden or 404 Not Found"
          }
        }
      ]
    },
    {
      "name": "5. Authorization & Role-Based Access",
      "item": [
        {
          "name": "Unauthenticated Request (should be 401)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/obras",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "obras"]
            }
          }
        },
        {
          "name": "Invalid JWT Token (should be 401)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalid.token.here"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/obras",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "obras"]
            }
          }
        },
        {
          "name": "Access Admin Endpoint as Non-Admin (should be 403)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/kyc/pendentes",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "kyc", "pendentes"]
            }
          }
        }
      ]
    },
    {
      "name": "6. Input Validation",
      "item": [
        {
          "name": "Invalid CPF (should be 400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\":\"Test\",\"email\":\"test@test.com\",\"cpf\":\"invalid-cpf\",\"telefone\":\"11999999999\",\"senha\":\"TestPass123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/registrar",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "auth", "registrar"]
            }
          }
        },
        {
          "name": "Weak Password (should be 400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\":\"Test\",\"email\":\"test@test.com\",\"cpf\":\"11144477735\",\"telefone\":\"11999999999\",\"senha\":\"123\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/registrar",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "auth", "registrar"]
            }
          }
        },
        {
          "name": "XSS Attempt (should sanitize)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\":\"<script>alert('xss')</script>\",\"email\":\"xss@test.com\",\"cpf\":\"11144477735\",\"telefone\":\"11999999999\",\"senha\":\"TestPass123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/registrar",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "auth", "registrar"]
            }
          }
        }
      ]
    },
    {
      "name": "7. Security Headers",
      "item": [
        {
          "name": "Check Security Headers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "health"]
            },
            "description": "Response should include:\n- X-Content-Type-Options: nosniff\n- X-Frame-Options: DENY\n- Content-Security-Policy\n- Strict-Transport-Security (HSTS)"
          }
        }
      ]
    },
    {
      "name": "8. Token Management",
      "item": [
        {
          "name": "Register User for Logout Test",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\":\"Logout Test\",\"email\":\"logout-{{$timestamp}}@test.com\",\"cpf\":\"11144477735\",\"telefone\":\"11999999999\",\"senha\":\"TestPass123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/registrar",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "auth", "registrar"]
            }
          }
        },
        {
          "name": "Logout User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{logout_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "auth", "logout"]
            }
          }
        },
        {
          "name": "Try to Use Token After Logout (should be 401)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{logout_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/obras",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "v1", "obras"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4000"
    },
    {
      "key": "user_token",
      "value": ""
    },
    {
      "key": "user1_token",
      "value": ""
    },
    {
      "key": "user2_token",
      "value": ""
    },
    {
      "key": "obra_id",
      "value": ""
    },
    {
      "key": "logout_token",
      "value": ""
    }
  ]
}
