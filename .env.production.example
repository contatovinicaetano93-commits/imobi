# ========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env.production and fill in values

# === FRONTEND (Vercel) ===
NEXT_PUBLIC_API_URL=https://imobi-api-prod.railway.app

# === BACKEND (Railway/NestJS) ===
NODE_ENV=production
PORT=3000

# === DATABASE ===
# Railway injects DATABASE_URL automatically
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://imobi:PASSWORD@localhost:5432/imobi_production

# === REDIS CACHE ===
# Railway injects REDIS_HOST and REDIS_PORT automatically
REDIS_HOST=localhost
REDIS_PORT=6379

# === AUTHENTICATION ===
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be >64 characters for security
JWT_SECRET=your-secure-jwt-secret-longer-than-64-characters-here-change-this

# === ENCRYPTION ===
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=your-base64-encoded-encryption-key-change-this

# === CORS ===
# Should point to your Vercel domain
CORS_ORIGIN=https://seu-projeto.vercel.app

# === AWS S3 (Optional - for file uploads) ===
# AWS_REGION=sa-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_S3_BUCKET=imobi-files

# === LOGGING ===
LOG_LEVEL=info

# === RATE LIMITING ===
# Auth endpoints: max 10 requests per 60 seconds
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
