# Production Environment Template
# Copy this to .env.production and fill in actual values
# DO NOT commit .env.production to git

# Node environment
NODE_ENV=production
PORT=4000

# ============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================================================
# PostgreSQL connection string with PostGIS extension
DATABASE_URL="postgresql://user:password@host:5432/imobi_prod?schema=public"

# ============================================================================
# REDIS CONFIGURATION (REQUIRED - pick ONE method)
# ============================================================================
# Method 1: Single Redis URL (Upstash, Render, etc.)
# Format: redis://[default]:[password]@[host]:[port]
REDIS_URL="redis://default:your_redis_password@your-redis-host.upstash.io:6379"

# Method 2: Separate host and port (leave REDIS_URL empty if using this)
# REDIS_HOST="your-redis-host.upstash.io"
# REDIS_PORT="6379"
# REDIS_PASSWORD="your_redis_password"

# ============================================================================
# EMAIL CONFIGURATION (REQUIRED - pick ONE provider)
# ============================================================================
# Provider options: sendgrid | ses | smtp (default: smtp)
EMAIL_PROVIDER="sendgrid"

# SendGrid Configuration
SENDGRID_API_KEY="your_sendgrid_api_key"

# AWS SES Configuration (alternative to SendGrid)
# EMAIL_PROVIDER="ses"
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your_aws_access_key"
# AWS_SECRET_ACCESS_KEY="your_aws_secret_key"

# SMTP Configuration (alternative, for simple mail servers)
# EMAIL_PROVIDER="smtp"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your_email@gmail.com"
# SMTP_PASS="your_app_password"
# SMTP_SECURE="false"

# ============================================================================
# FIREBASE CONFIGURATION (REQUIRED - for push notifications)
# ============================================================================
FIREBASE_PROJECT_ID="your_firebase_project_id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com"

# ============================================================================
# AWS S3 CONFIGURATION (REQUIRED - for evidence photos)
# ============================================================================
AWS_S3_BUCKET="imobi-prod-evidence"
AWS_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your_aws_access_key_for_s3"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key_for_s3"

# ============================================================================
# OPTIONAL: CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGIN="https://app.imobi.com.br,https://www.imobi.com.br"

# ============================================================================
# OPTIONAL: OAuth & External Services
# ============================================================================
# Google OAuth (if implemented)
# GOOGLE_CLIENT_ID="your_google_client_id"
# GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ============================================================================
# ERROR TRACKING & MONITORING (OPTIONAL - strongly recommended for production)
# ============================================================================
# Sentry: Real-time error tracking and performance monitoring
# Sign up at https://sentry.io/signup and create a project
# Note: You need TWO separate projects - one for API (Node.js), one for Web (JavaScript/Next.js)

# API (NestJS + Fastify) - Node.js project
SENTRY_DSN="https://your_public_key@o123456.ingest.sentry.io/123456"
SENTRY_RELEASE="1.0.0"
SENTRY_ENABLE_PROFILER="true"

# Web (Next.js) - JavaScript/Browser project
# Must be NEXT_PUBLIC to be available in browser
NEXT_PUBLIC_SENTRY_DSN="https://your_public_key@o123456.ingest.sentry.io/654321"
NEXT_PUBLIC_SENTRY_RELEASE="1.0.0"

# ============================================================================
# VALIDATION NOTES
# ============================================================================
# On application startup, this configuration will be validated:
# - DATABASE_URL must be set and PostgreSQL must be accessible
# - REDIS: Either REDIS_URL or (REDIS_HOST + REDIS_PORT) must be configured
# - EMAIL: One of SendGrid/SES/SMTP must be fully configured
# - FIREBASE: All three credentials must be present
# - AWS_S3: Bucket and region must be set
# - SENTRY_DSN: Optional but recommended for production monitoring
#
# If any required configuration is missing, the application will fail to start
# with a clear error message indicating what needs to be fixed.
