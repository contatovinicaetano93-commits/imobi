{
  "buildCommand": "pnpm install && pnpm build --filter=@imbobi/schemas --filter=@imbobi/core --filter=@imbobi/ui && pnpm build --filter=@imbobi/web",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "env": {
    "NODE_ENV": "production",
    "NEXT_PUBLIC_API_URL": "https://api.imobi.com",
    "CORS_ORIGIN": "https://imobi.vercel.app,https://api.imobi.com,https://imobi.com.br,http://localhost:3000",
    "EMAIL_PROVIDER": "sendgrid"
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
