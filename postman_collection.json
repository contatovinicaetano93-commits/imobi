            "url": {
              "raw": "{{baseUrl}}/parcelas/{{workId}}",
              "host": ["{{baseUrl}}"],
              "path": ["parcelas", "{{workId}}"]
            }
          }
        },
        {
          "name": "Pay Installment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"metodo\": \"PIX\",\n  \"referencia\": \"00020126580014br.gov.bcb.pix...\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/parcelas/{{installmentId}}/pagar",
              "host": ["{{baseUrl}}"],
              "path": ["parcelas", "{{installmentId}}", "pagar"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
