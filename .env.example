# ── API ────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── DATABASE ────────────────────────────────────────
# PostgreSQL + PostGIS
# LOCAL DEV: Use local instance
# AWS RDS: Use endpoint from Terraform output
DATABASE_URL=postgresql://imbobi:senha@localhost:5432/imbobi_dev

# ── REDIS (BullMQ) ───────────────────────────────────
# LOCAL DEV: Use local Redis instance
# AWS ElastiCache: Use endpoint from Terraform output
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://elasticache-endpoint.cache.amazonaws.com:6379 (alternative format)

# JWT
JWT_SECRET=troque_por_uma_chave_de_pelo_menos_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Data Encryption (AES-256-GCM)
# ENCRYPTION_KEY must be 32 bytes base64-encoded (generate with: openssl rand -base64 32)
# Used for: token refresh encryption, sensitive data protection
ENCRYPTION_KEY=D+Tq00RvRIfTL66ZbEnn7iAEryHRVyYLuCfUzY49pJM=

# ── AWS ────────────────────────────────────────────
# AWS Credentials (required for S3, SES, RDS connections)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 (Evidence photos storage) - Already implemented
S3_BUCKET=imbobi-evidencias

# RDS PostgreSQL (Phase 1)
# Format: postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE
# Get from: terraform output rds_database_url
# DATABASE_URL env var above takes precedence
# RDS_HOST=imbobi-postgres.xxxxx.us-east-1.rds.amazonaws.com
# RDS_PORT=5432

# ElastiCache Redis (Phase 1)
# Get from: terraform output elasticache_url
# REDIS_URL format: redis://HOST:PORT
# REDIS_HOST and REDIS_PORT above take precedence
# REDIS_URL=redis://imbobi-redis.xxxxx.cache.amazonaws.com:6379

# ── WEB (Next.js) ──────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.imbobi.com.br

# ── MOBILE (Expo) ──────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:4000
EAS_PROJECT_ID=

# ── EMAIL ──────────────────────────────────────────
# Option 1: AWS SES (Recommended for AWS Phase 1)
#   - 50,000 emails/day free
#   - Requires verified email/domain in SES
USE_AWS_SES=false
SES_FROM_EMAIL=noreply@imbobi.com.br
# AWS_REGION is already defined above, used by SES

# Option 2: SMTP (SendGrid, Gmail, etc.)
#   - Configure SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS
#   - SES takes precedence if USE_AWS_SES=true
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
SMTP_FROM=noreply@imbobi.com
APP_URL=http://localhost:3000

# ── Integrações externas ───────────────────────────
# KYC
UNICO_API_KEY=
SERPRO_TOKEN=

# ── KYC/Identity Validation (External APIs) ────────
# Unico (Brazilian identity validation)
UNICO_API_KEY=...

# SERPRO (Gov't digital certificate queries)
SERPRO_TOKEN=...
