# ── API ────────────────────────────────────────────
PORT=4000
NODE_ENV=production
CORS_ORIGIN=https://imbobi.com.br

# PostgreSQL + PostGIS (required for production)
# Format: postgresql://user:password@host:port/database
# PostGIS extension required for location validation
DATABASE_URL=postgresql://imbobi:senha@localhost:5432/imbobi_prod

# Redis Cache + BullMQ (required for production)
# Used for: caching (5min TTL), job queue (liberacao-parcela, notifications)
REDIS_HOST=redis.imbobi.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
# JWT_SECRET must be at least 64 characters and strong random string
JWT_SECRET=gerar_uma_chave_aleatoria_com_min_64_caracteres_use_openssl_rand_base64_48
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 (Evidence photos storage)
# Required: S3 bucket for storing construction evidence photos
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=imbobi-evidencias-prod

# ── WEB (Next.js) ──────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.imbobi.com.br

# ── MOBILE (Expo) ──────────────────────────────────
EXPO_PUBLIC_API_URL=https://api.imbobi.com.br
EAS_PROJECT_ID=...

# ── Email Provider (Production-Ready) ──────────────
# Options: "sendgrid", "ses", or "smtp"
# Default: smtp (configure SMTP_* vars below)

# Option 1: SendGrid (Recommended for production)
# Set EMAIL_PROVIDER=sendgrid and configure:
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG...

# Option 2: AWS SES (If already using AWS)
# Set EMAIL_PROVIDER=ses and configure AWS_* vars above
# SES endpoint: email-smtp.{region}.amazonaws.com

# Option 3: SMTP Generic (self-hosted or third-party)
# Set EMAIL_PROVIDER=smtp and configure:
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG...
SMTP_FROM=noreply@imbobi.com.br
APP_URL=https://imbobi.com.br

# ── Firebase Cloud Messaging (Push Notifications) ──
# Required for production push notifications
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=imbobi-prod
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-admin@imbobi-prod.iam.gserviceaccount.com

# ── KYC/Identity Validation (External APIs) ────────
# Unico (Brazilian identity validation)
UNICO_API_KEY=...

# SERPRO (Gov't digital certificate queries)
SERPRO_TOKEN=...

# ── Advanced Production Configuration ────────────────

# Email retry configuration
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY_MS=1000
EMAIL_RETRY_BACKOFF=2

# Firebase/FCM advanced settings
FCM_TTL=2419200
FCM_MAX_RETRIES=3
FCM_RETRY_DELAY_MS=1000
FCM_DEBUG=false

# Redis advanced settings (optional, uses defaults if not set)
# Useful for Redis Sentinel, Cluster, or custom setups
# If set, REDIS_URL takes precedence over individual HOST/PORT/PASSWORD
# REDIS_URL=redis://:password@host:port/db

# ── APM & Monitoring (Production) ────────────────────
# Application Performance Monitoring - New Relic
# Free tier: 100GB/month (sufficient for most use cases)
# Get license key from: https://one.newrelic.com/ → Account Settings → API keys
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_ENABLED=true

# Error Tracking - Sentry
# Real-time error tracking and session replay
# Free tier: 5,000 events/month
# Get DSN from: https://sentry.io/ → Settings → Projects
SENTRY_DSN=
SENTRY_ENABLED=true
SENTRY_ENVIRONMENT=production
SENTRY_AUTH_TOKEN=

# Alternative: DataDog APM (if preferred over New Relic)
# Requires DataDog agent running on host
# DATADOG_API_KEY=
# DD_SERVICE=imbobi-api
# DD_ENV=production
# DD_VERSION=1.0.0
# DD_TRACE_SAMPLE_RATE=0.1
