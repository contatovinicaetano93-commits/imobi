# IMOBI API (NestJS) — copy to services/api/.env.local
# Web (Next.js, port 3000): see apps/web/.env.local.example
NODE_ENV=development
PORT=4000
API_VERSION=1.0.0
HOSTNAME=0.0.0.0
APP_URL=https://imobi-web.vercel.app

# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/imobi
DATABASE_POOL_SIZE=25
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECT_TIMEOUT=10000

# REDIS / CACHE
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CONNECT_TIMEOUT=5000

# JWT & AUTH
JWT_SECRET=your-256-bit-secret-key-here-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=HS256

# ENCRYPTION
ENCRYPTION_KEY=your-256-bit-encryption-key-min-32-chars
ENCRYPTION_ALGORITHM=aes-256-gcm
IV_LENGTH=12

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_STORAGE=redis

# API TIERS
TIER_FREE_QUOTA=100
TIER_PREMIUM_QUOTA=1000
TIER_ENTERPRISE_QUOTA=10000

# OBSERVABILITY
SENTRY_DSN=
SENTRY_ENABLED=true
LOG_LEVEL=info
STRUCTURED_LOGGING=true
PROMETHEUS_ENABLED=true

# OPENAPI
OPENAPI_ENABLED=true
SWAGGER_ENABLED=true
SWAGGER_PATH=/docs

# EXTERNAL SERVICES
SENDGRID_API_KEY=
SLACK_WEBHOOK_URL=
AWS_REGION=us-east-1
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=imobi-storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SECURITY
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://app.imobi.com
CSRF_PROTECTION=true
HELMET_ENABLED=true
RATE_LIMIT_ENABLED=true
API_KEY_ROTATION_DAYS=90

# FEATURE FLAGS
FEATURE_KYC_ENABLED=true
FEATURE_VISTORIA_ENABLED=true
FEATURE_DUE_DILIGENCE_ENABLED=true
FEATURE_MARKETPLACE_ENABLED=false

# INTERNAL
INTERNAL_API_TIMEOUT=30000
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_DELAY=1000
RETRY_MAX_DELAY=10000
