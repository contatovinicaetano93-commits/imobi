# ── API ────────────────────────────────────────────
PORT=4000
NODE_ENV=production
CORS_ORIGIN=https://imbobi.com.br

# PostgreSQL + PostGIS (required for production)
# Format: postgresql://user:password@host:port/database
# PostGIS extension required for location validation
DATABASE_URL=postgresql://imbobi:senha@localhost:5432/imbobi_prod

# Redis Cache + BullMQ (required for production)
# Used for: caching (5min TTL), job queue (liberacao-parcela, notifications)
REDIS_HOST=redis.imbobi.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
# JWT_SECRET must be at least 64 characters and strong random string
JWT_SECRET=gerar_uma_chave_aleatoria_com_min_64_caracteres_use_openssl_rand_base64_48
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 (Evidence photos storage)
# Required: S3 bucket for storing construction evidence photos
AWS_S3_BUCKET=imbobi-evidencias-prod
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# ── WEB (Next.js) ──────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.imbobi.com.br
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_RELEASE=1.0.0

# ── MOBILE (Expo) ──────────────────────────────────
EXPO_PUBLIC_API_URL=https://api.imbobi.com.br
EAS_PROJECT_ID=...

# ── Email Provider (Production-Ready) ──────────────
# Options: "sendgrid", "ses", or "smtp"
# Default: smtp (configure SMTP_* vars below)

# Escolha UM provider e comente os outros
# Option 1: SendGrid (Recommended)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG...

# Option 2: AWS SES
# EMAIL_PROVIDER=ses  (reusa AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY acima)

# Option 3: SMTP genérico
# EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG...
SMTP_FROM=noreply@imbobi.com.br
APP_URL=https://imbobi.com.br

# ── Firebase Cloud Messaging (Push Notifications) ──
# Required for production push notifications
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=imbobi-prod
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-admin@imbobi-prod.iam.gserviceaccount.com

# ── KYC/Identity Validation (External APIs) ────────
# Unico (Brazilian identity validation)
UNICO_API_KEY=...

# SERPRO (Gov't digital certificate queries)
SERPRO_TOKEN=...

# ── Error Tracking & Monitoring ──────────────────────
# Sentry (Error tracking and performance monitoring)
# Get DSN from https://sentry.io/projects/
# Required in production for error tracking
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_RELEASE=1.0.0
SENTRY_ENABLE_PROFILER=true
SENTRY_TRACING_SAMPLE_RATE=0.1
SENTRY_ERROR_SAMPLE_RATE=1.0

# Slack Notifications (for backup alerts)
# Optional: configure for infrastructure monitoring
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# AWS Backup Configuration (for automated backups)
# Required if using automated backups to S3
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are reused from above
# S3 backup buckets will be: imobi-backups-{environment}

# ── Setup & Development Utilities ────────────────────
# SETUP_SECRET: secret key for GET /api/v1/setup endpoint (creates staff accounts)
# Must be set to use the setup endpoint; leave blank to disable
SETUP_SECRET=gerar_string_aleatoria_forte_aqui

# SWAGGER_ENABLED: expose Swagger UI (/api/docs) in production
# In development the Swagger UI is always enabled
# Set to "true" only for internal staging environments
SWAGGER_ENABLED=false

# ── Setup Staff User Passwords ─────────────────────────
# Passwords for staff accounts created via GET /api/v1/setup
# If unset, uses defaults (insecure — always set in production)
SETUP_ADMIN_SENHA=gerar_senha_forte_admin
SETUP_ADMIN2_SENHA=gerar_senha_forte_admin2
SETUP_GESTOR_SENHA=gerar_senha_forte_gestor
SETUP_ENG_SENHA=gerar_senha_forte_eng
SETUP_COMERCIAL_SENHA=gerar_senha_forte_comercial
SETUP_CONSTRUTOR_SENHA=gerar_senha_forte_construtor
SETUP_TOMADOR_SENHA=gerar_senha_forte_tomador

# ── Business Rule Tuning ──────────────────────────────
# Credit default monthly interest rate (e.g. 0.0099 = 0.99%/month)
TAXA_MENSAL_DEFAULT=0.0099

# GPS accuracy threshold for evidence upload validation (meters)
GPS_MAX_ACCURACY_METROS=15

# GPS geo-fence radius for obra location validation (meters)
GPS_RAIO_VALIDACAO_M=50

# Account deletion grace period in days (LGPD Article 17)
EXCLUSAO_GRACE_PERIOD_DAYS=30

# Lookback window in months for admin metrics dashboard
METRICAS_LOOKBACK_MONTHS=12

# Partner referral commission percentage (e.g. 5 = 5%)
PARCEIRO_PERCENTUAL_COMISSAO=5

# Days a partner referral remains valid before expiry
PARCEIRO_VALIDADE_INDICACAO_DIAS=90

# ── BullMQ / Redis Queue Tuning ────────────────────────
# BULL_JOB_ATTEMPTS: max retry attempts per job (default: 3)
# BULL_JOB_BACKOFF_DELAY_MS: initial exponential backoff in ms (default: 5000)
# BULL_COMPLETED_TTL_SECONDS: TTL for completed jobs in Redis (default: 86400 = 24h)
# BULL_FAILED_TTL_SECONDS: TTL for failed jobs in Redis (default: 604800 = 7d)
BULL_JOB_ATTEMPTS=3
BULL_JOB_BACKOFF_DELAY_MS=5000
BULL_COMPLETED_TTL_SECONDS=86400
BULL_FAILED_TTL_SECONDS=604800

# ── Fintech / Security ─────────────────────────────────
# AES-256-GCM key for encrypting TOTP secrets at rest (must be >= 32 chars)
TOTP_ENCRYPTION_KEY=change-me-to-a-32-char-minimum-secret-key

# Outbox worker poll interval in ms (default: 10000 = 10s)
OUTBOX_POLL_INTERVAL_MS=10000

# Reconciliation worker run interval in ms (default: 3600000 = 1h)
RECONCILIACAO_INTERVAL_MS=3600000
