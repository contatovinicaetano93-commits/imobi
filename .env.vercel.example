# Vercel Environment Variables Configuration Guide
#
# These variables must be configured in Vercel Dashboard:
# 1. Go to Project Settings → Environment Variables
# 2. Add each variable with the appropriate scope (Production, Preview, Development)
# 3. For secrets (marked with [SECRET]), use Vercel Secrets management

# Database Configuration [SECRET]
# Production connection string
DATABASE_URL=postgresql://user:password@host:5432/imobi_prod

# Sentry Configuration [SECRET]
# DSN for error tracking in production
NEXT_PUBLIC_SENTRY_DSN=https://key@sentry.io/project_id

# Firebase Configuration (if used)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_domain.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_bucket.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# AWS S3 Configuration [SECRET]
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=imobi-prod-uploads

# SendGrid Configuration [SECRET]
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Redis Configuration [SECRET]
REDIS_URL=redis://:password@host:6379

# API Configuration
NEXT_PUBLIC_API_URL=https://api.imobi.com
CORS_ORIGIN=https://imobi.vercel.app,https://api.imobi.com,https://imobi.com.br

# Application Configuration
NODE_ENV=production
EMAIL_PROVIDER=sendgrid

# Instructions:
# 1. Copy values from your production .env file
# 2. For each SECRET variable, create it in Vercel with "Encrypted" toggle enabled
# 3. For NEXT_PUBLIC_* variables, these are safe to expose in client code
# 4. Test deployment on Preview environment first
# 5. Monitor Sentry dashboard for errors post-deployment
