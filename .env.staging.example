# Staging Environment Configuration
# IMPORTANT: Set actual secrets in Render dashboard, not in this file
# This file uses placeholders for security scanning compliance

NODE_ENV=staging
PORT=4000

# Database (configure in Render > Environment Variables)
DATABASE_URL=postgresql://user:password@your-staging-db.rds.amazonaws.com:5432/imobi_staging

# Redis (configure in Render > Environment Variables)
REDIS_HOST=your-staging-redis.cache.amazonaws.com
REDIS_PORT=6379

# JWT & Encryption (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-min-64-chars-replace-in-render
ENCRYPTION_KEY=your-encryption-key-32-chars-replace-in-render

# CORS
CORS_ORIGIN=https://staging.imbobi.com,https://api.staging.imbobi.com

# Monitoring
SENTRY_DSN=https://your-sentry-dsn-key@sentry.io/project-id

# AWS S3
AWS_REGION=us-east-1
AWS_S3_BUCKET=imobi-staging-assets
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Email (SES)
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-ses-smtp-user
SMTP_PASS=your-ses-smtp-password
SMTP_FROM=noreply@staging.imbobi.com

# Mobile/API
EXPO_PUBLIC_API_URL=https://api.staging.imbobi.com/api/v1
EAS_PROJECT_ID=your-eas-project-id
