# ──────────────────────────────────────────────────────────────────────────────
# imbobi — STAGING ENVIRONMENT CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
#
# IMPORTANT: Copy this file to .env.staging and update all values
#            NEVER commit .env.staging to git (it contains sensitive data)
#
# Generated automatically by: ./scripts/setup-staging.sh
# Last Updated: 2026-05-29
#
# ──────────────────────────────────────────────────────────────────────────────
# API CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────

# Server Port
PORT=4000

# Environment
NODE_ENV=staging

# CORS Configuration
# Allowed origins for cross-origin requests (comma-separated)
# Include: web frontend, mobile (EAS build), and local development
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,http://staging.imbobi.local:3000,http://staging.imbobi.local:8081

# ──────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
#
# PostgreSQL with PostGIS support (geolocation validation)
#
# LOCAL DEVELOPMENT (using docker-compose.staging.yml):
#   DATABASE_URL=postgresql://imobi:staging_password_secure_12345@localhost:5433/imobi_staging
#
# AWS RDS (change these values):
#   DATABASE_URL=postgresql://imobi:secure-password@imobi-staging.xxxxx.us-east-1.rds.amazonaws.com:5432/imobi_staging
#
# Connection string format: postgresql://user:password@host:port/database?schema=public
#
# PostGIS requirement:
#   - Extension must be installed (usually automatic)
#   - Required for: GPS validation, location distance calculations
#

DATABASE_URL=postgresql://imobi:staging_password_secure_12345@localhost:5433/imobi_staging

# ──────────────────────────────────────────────────────────────────────────────
# REDIS CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
#
# Redis for: Caching (5min TTL), Job Queue (BullMQ), Rate limiting
#
# LOCAL DEVELOPMENT (using docker-compose.staging.yml):
#   REDIS_HOST=localhost
#   REDIS_PORT=6380
#   REDIS_PASSWORD=
#
# AWS ElastiCache (change these values):
#   REDIS_HOST=imobi-redis-staging.xxxxx.cache.amazonaws.com
#   REDIS_PORT=6379
#   REDIS_PASSWORD=your-auth-token (if enabled)
#

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION & ENCRYPTION
# ──────────────────────────────────────────────────────────────────────────────
#
# JWT_SECRET:
#   - Minimum 64 characters (production requirement)
#   - Generate: openssl rand -base64 48
#   - Used to sign/verify JWT tokens
#
# ENCRYPTION_KEY:
#   - 32 bytes, base64-encoded (256-bit key for AES-256-GCM)
#   - Generate: openssl rand -base64 32
#   - Used to encrypt sensitive data (CPF, bank info, etc.)
#

JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_MIN_64_CHARS_EXAMPLE_openssl_rand_base64_48
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

ENCRYPTION_KEY=REPLACE_WITH_SECURE_RANDOM_STRING_32_CHARS_EXAMPLE_openssl_rand_base64_32

# ──────────────────────────────────────────────────────────────────────────────
# AWS S3 CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
#
# S3 Storage for construction site evidence photos
#
# Setup:
#   1. Create S3 bucket: imbobi-evidencias-staging
#   2. Create IAM user with S3 access
#   3. Generate access key + secret
#   4. Add bucket CORS policy (allow web/mobile uploads)
#
# CORS Policy for S3 bucket:
# [
#   {
#     "AllowedOrigins": ["http://localhost:3000", "http://localhost:4000"],
#     "AllowedMethods": ["GET", "PUT", "POST", "DELETE"],
#     "AllowedHeaders": ["*"],
#     "MaxAgeSeconds": 3000
#   }
# ]
#

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA_YOUR_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
S3_BUCKET=imbobi-evidencias-staging
S3_PUBLIC_URL=https://imbobi-evidencias-staging.s3.amazonaws.com

# ──────────────────────────────────────────────────────────────────────────────
# WEB FRONTEND CONFIGURATION (Next.js)
# ──────────────────────────────────────────────────────────────────────────────

# Public API URL (used by browser/frontend)
# - Local: http://localhost:4000
# - Staging: http://api.staging.imbobi.local or https://api-staging.imbobi.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# Next.js specific
NEXT_PUBLIC_ENVIRONMENT=staging

# ──────────────────────────────────────────────────────────────────────────────
# MOBILE FRONTEND CONFIGURATION (Expo/React Native)
# ──────────────────────────────────────────────────────────────────────────────

# Public API URL (used by mobile app)
EXPO_PUBLIC_API_URL=http://localhost:4000

# EAS (Expo Application Services) Project ID
# Get from: eas.json or https://expo.dev dashboard
EAS_PROJECT_ID=your_eas_project_id_here

# ──────────────────────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
#
# Options: "sendgrid", "ses", or "smtp"
#
# SENDGRID (Recommended for staging):
#   - Create free account: https://sendgrid.com
#   - Generate API key
#   - Set EMAIL_PROVIDER=sendgrid and add SENDGRID_API_KEY
#
# AWS SES (if already using AWS):
#   - Verify email address in SES console
#   - Set EMAIL_PROVIDER=ses
#   - Use AWS credentials above
#
# Generic SMTP (self-hosted or third-party):
#   - Set EMAIL_PROVIDER=smtp
#   - Configure SMTP_* variables below
#

EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Alternative: AWS SES
# EMAIL_PROVIDER=ses
# (Uses AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)

# Alternative: Generic SMTP
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.your_sendgrid_api_key_here
# SMTP_FROM=noreply@imbobi.com.br

# App email settings
APP_URL=http://staging.imbobi.local:3000
SUPPORT_EMAIL=suporte@imbobi.com.br

# ──────────────────────────────────────────────────────────────────────────────
# FIREBASE CLOUD MESSAGING
# ──────────────────────────────────────────────────────────────────────────────
#
# Used for push notifications to mobile devices
#
# Setup:
#   1. Create Firebase project: https://console.firebase.google.com
#   2. Go to Project Settings → Service Accounts
#   3. Create new private key
#   4. Copy values below (keep private key multiline format)
#
# Private Key Format (preserve newlines):
#   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE....\n-----END PRIVATE KEY-----\n"
#

FIREBASE_PROJECT_ID=imbobi-staging
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-admin@imbobi-staging.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://imbobi-staging.firebaseio.com

# ──────────────────────────────────────────────────────────────────────────────
# KYC & IDENTITY VALIDATION
# ──────────────────────────────────────────────────────────────────────────────
#
# External services for Brazilian document/identity validation
#
# Unico (Face + Document Validation):
#   - https://www.unico.io/
#   - Validates CPF, facial recognition
#
# SERPRO (Government API Access):
#   - Brazilian government service for document validation
#   - Requires API token
#

UNICO_API_KEY=test_your_unico_api_key_here
UNICO_ENVIRONMENT=test

SERPRO_TOKEN=test_your_serpro_token_here
SERPRO_ENVIRONMENT=test

# ──────────────────────────────────────────────────────────────────────────────
# LOGGING & MONITORING
# ──────────────────────────────────────────────────────────────────────────────

# Log Level
# Options: error, warn, info, debug, trace
LOG_LEVEL=debug

# Sentry Error Tracking (optional)
# Get from: https://sentry.io
# Format: https://key@sentry.io/project-id
SENTRY_DSN=

# Request Logging
LOG_HTTP_REQUESTS=true
LOG_DATABASE_QUERIES=true

# ──────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS & EXPERIMENTAL
# ──────────────────────────────────────────────────────────────────────────────

# Enable experimental features
FEATURE_GPS_VALIDATION=true
FEATURE_PHOTO_OCR=false
FEATURE_AI_ANALYSIS=false

# ──────────────────────────────────────────────────────────────────────────────
# NOTES & GUIDELINES
# ──────────────────────────────────────────────────────────────────────────────
#
# CRITICAL:
#   ✓ Never commit .env.staging (it has secrets)
#   ✓ Use strong random values for JWT_SECRET and ENCRYPTION_KEY
#   ✓ Update AWS credentials for your staging environment
#   ✓ Use staging-tier credentials (not production)
#
# DEVELOPMENT WORKFLOW:
#   1. Copy .env.staging.example → .env.staging
#   2. Update placeholders with your values
#   3. Run: ./scripts/setup-staging.sh
#   4. Run: pnpm dev (or ./scripts/deploy.sh)
#
# CREDENTIALS GENERATION:
#   JWT_SECRET (min 64 chars):
#     openssl rand -base64 48
#     node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
#
#   ENCRYPTION_KEY (32 bytes, base64):
#     openssl rand -base64 32
#     node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# DOCKER PORTS:
#   PostgreSQL: 5433 (mapped to 5432 inside container)
#   Redis: 6380 (mapped to 6379 inside container)
#   API: 4000
#   Web: 3000
#   Mobile: 8081 (Expo dev server)
#
# DATABASE SCHEMA:
#   Public schema: imobi_staging
#   PostGIS extensions: point, geometry, geography types
#
# STORAGE:
#   S3 bucket structure: /staging/[user-id]/[date]/[photo-id].jpg
#   Max file size: 10MB per photo
#
# SECURITY:
#   - All connections use HTTPS in production
#   - Database credentials rotated monthly
#   - S3 bucket policies restrict to app only
#   - Firebase keys scoped to staging project only
#
# DOCUMENTATION:
#   - Full checklist: STAGING_CHECKLIST.md
#   - Deployment guide: scripts/deploy.sh
#   - Health checks: scripts/health-check.sh
#   - Architecture: CLAUDE.md
#
# ──────────────────────────────────────────────────────────────────────────────
