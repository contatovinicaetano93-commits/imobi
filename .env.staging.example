# Staging Environment Configuration
# Copy this to your staging server and fill in actual values

# Database
DATABASE_URL="postgresql://user:password@staging-db:5432/imbobi_staging"

# Redis
REDIS_HOST="staging-redis"
REDIS_PORT=6379

# JWT & Security
JWT_SECRET="your-staging-jwt-secret-min-64-chars-generated-securely-here-abcdefgh"
ENCRYPTION_KEY="your-staging-encryption-key-base64-32-bytes-generated-securely-here="

# CORS
CORS_ORIGIN="https://staging.imbobi.com.br,https://web-staging.imbobi.com.br"

# API
NODE_ENV="production"
PORT=4000

# AWS S3 (Obra photos)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="staging-access-key"
AWS_SECRET_ACCESS_KEY="staging-secret-key"
AWS_S3_BUCKET="imbobi-staging-fotos"

# Email
SMTP_HOST="smtp.staging.example.com"
SMTP_PORT=587
SMTP_USER="noreply@imbobi.com.br"
SMTP_PASSWORD="staging-smtp-password"

# Firebase (Push notifications)
FIREBASE_PROJECT_ID="imbobi-staging"
FIREBASE_PRIVATE_KEY="staging-firebase-key"
FIREBASE_CLIENT_EMAIL="firebase@imbobi-staging.iam.gserviceaccount.com"

# Logging
LOG_LEVEL="info"
