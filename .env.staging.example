# ── STAGING ENVIRONMENT CONFIGURATION ────────────────────
# Copy this file to .env.staging and fill in the values
# Never commit .env.staging to git repository

# ── API ────────────────────────────────────────────
PORT=4000
NODE_ENV=staging
CORS_ORIGIN=http://staging.imbobi.local:3000,http://localhost:3000

# PostgreSQL + PostGIS (Docker Compose: postgres:5433)
# When using docker-compose.staging.yml:
#   Host: localhost (or postgres service name if running in container)
#   Port: 5433 (mapped from 5432)
#   User: imobi
#   Password: staging_password_secure_12345
#   Database: imobi_staging
DATABASE_URL=postgresql://imobi:staging_password_secure_12345@localhost:5433/imobi_staging

# Redis (Docker Compose: redis:6380)
# When using docker-compose.staging.yml:
#   Host: localhost
#   Port: 6380 (mapped from 6379)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# JWT Authentication
# Generate: openssl rand -base64 48 (min 64 chars)
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_MIN_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Data Encryption (AES-256-GCM)
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=REPLACE_WITH_SECURE_RANDOM_STRING_32_CHARS

# AWS S3 (Evidence photos)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=imbobi-evidencias-staging

# ── WEB (Next.js) ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── MOBILE (Expo) ──────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:4000
EAS_PROJECT_ID=...

# ── Email Provider ────────────────────────────────
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG...

# ── Firebase Cloud Messaging ──────────────────────
FIREBASE_PROJECT_ID=imbobi-staging
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-admin@imbobi-staging.iam.gserviceaccount.com

# ── KYC/Identity Validation ────────────────────────
UNICO_API_KEY=test_...
SERPRO_TOKEN=test_...

# ── LOGGING ────────────────────────────────────────
LOG_LEVEL=debug
SENTRY_DSN=
