# Copie para .env.render.local (gitignored) e SUBSTITUA todos os CHANGE_ME
# Dashboard: https://dashboard.render.com
#
# NUNCA deixe "…" ou textos de exemplo — quebram os scripts de deploy.

RENDER_API_KEY=CHANGE_ME_rnd_api_key_from_render_dashboard
RENDER_SERVICE_ID=srv-d8fl07h9rddc73ajs7ag

# Postgres -> Connect -> External Database URL (URL completa, nao resumida)
DATABASE_URL=CHANGE_ME_postgresql://user:password@host.region-postgres.render.com/imobi_prod

# Redis: Internal/External URL do servico Redis no Render
REDIS_URL=CHANGE_ME_redis://default:password@host:6379

JWT_SECRET=CHANGE_ME_openssl_rand_base64_64
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
FIREBASE_PRIVATE_KEY="CHANGE_ME_multiline_private_key"

# Opcional: seed via HTTP (pnpm seed:staging -- --setup)
# Gere com: openssl rand -hex 32
SETUP_SECRET=
